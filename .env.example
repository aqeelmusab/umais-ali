# ── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# Vercel forwards client IP metadata through proxy headers.
# "1" trusts the first hop; use a number of hops or an IP/subnet for stricter setups.
TRUST_PROXY=1

# ── Resend (https://resend.com) ─────────────────────────────────────────────
# Create at https://resend.com/api-keys
RESEND_API_KEY=

# Verified sender. While testing you can use "onboarding@resend.dev".
# In production use a verified domain: "Umais Ali <hello@umaisali.com>"
CONTACT_FROM=Umais Ali <onboarding@resend.dev>

# Where contact form submissions are delivered.
CONTACT_TO=you@example.com

# Optional. Defaults to the submitter's email so you can reply directly.
CONTACT_REPLY_TO=

# ── Rate limiting ───────────────────────────────────────────────────────────
# Max POST /contact requests per IP per window.
CONTACT_RATE_WINDOW_MS=600000
CONTACT_RATE_MAX=5

# Disable HSTS when serving over plain http locally.
ENABLE_HSTS=true
