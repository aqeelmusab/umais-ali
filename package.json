{
  "name": "umais-ali",
  "version": "1.0.0",
  "private": true,
  "description": "Umais Ali — SEO Executive portfolio (Node + Express + Pug + HTMX + Tailwind).",
  "main": "dist/server.js",
  "scripts": {
    "build:css": "tailwindcss -i ./src/styles/main.css -o ./public/css/main.css --minify",
    "watch:css": "tailwindcss -i ./src/styles/main.css -o ./public/css/main.css --watch",
    "build:ts": "tsc",
    "build": "npm run build:css && npm run build:ts",
    "start": "node dist/server.js",
    "dev:server": "tsx watch src/server.ts",
    "dev": "npm-run-all --parallel watch:css dev:server",
    "typecheck:tests": "tsc -p tsconfig.test.json",
    "test": "tsx --test tests/**/*.test.ts"
  },
  "dependencies": {
    "express": "^4.21.2",
    "pug": "^3.0.3"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/pug": "^2.0.10",
    "npm-run-all": "^4.1.5",
    "tailwindcss": "^4.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
