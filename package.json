{
  "name": "umais-ali",
  "version": "2.4.7",
  "private": true,
  "description": "Umais Ali: SEO Executive portfolio (Node + Express + Pug + HTMX + Tailwind).",
  "main": "dist/server.js",
  "packageManager": "pnpm@11.11.0+sha512.4463f65fd80ed80d69bc1d4bf163ee94f605c7380fc318bb5b2ebe15f8cd12d49c51a4d59e951b401e764d3b6ca751cbf51bc50ed7001a6bcb4935e684c34882",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "sync": "astro sync",
    "typecheck": "astro check && pnpm run typecheck:tests",
    "typecheck:tests": "tsc -p tsconfig.test.json --noEmit",
    "test": "NODE_ENV=test tsx --test tests/**/*.test.ts",
    "lint": "biome check .",
    "fix": "biome check --write .",
    "format": "biome format --write .",
    "verify": "pnpm run sync && pnpm run typecheck && pnpm run test && pnpm run lint && pnpm run build",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/svelte": "^9.0.1",
    "@astrojs/vercel": "^11.0.2",
    "@resvg/resvg-js": "2.6.2",
    "@tailwindcss/cli": "4.3.2",
    "@tailwindcss/vite": "^4.3.2",
    "@types/express": "5.0.6",
    "@types/node": "24.13.3",
    "@types/pug": "2.0.10",
    "astro": "^7.0.7",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "express-rate-limit": "8.5.2",
    "gsap": "3.15.0",
    "helmet": "8.3.0",
    "htmx.org": "2.0.10",
    "motion": "^12.42.2",
    "pug": "3.0.4",
    "resend": "6.17.2",
    "satori": "0.26.0",
    "svelte": "^5.56.4",
    "tailwindcss": "4.3.2",
    "typescript": "6.0.3",
    "wawoff2": "2.0.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@biomejs/biome": "2.5.3",
    "npm-run-all": "4.1.5",
    "simple-git-hooks": "2.13.1",
    "tsx": "4.23.1"
  },
  "simple-git-hooks": {
    "pre-push": "pnpm install --frozen-lockfile --lockfile-only || (echo 'Lockfile out of sync. Run pnpm install.' && exit 1) && pnpm run typecheck && pnpm test"
  }
}
