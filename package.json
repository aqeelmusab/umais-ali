{
  "name": "umais-ali",
  "version": "2.4.6",
  "private": true,
  "description": "Umais Ali: SEO Executive portfolio (Node + Express + Pug + HTMX + Tailwind).",
  "main": "dist/server.js",
  "packageManager": "pnpm@11.10.0+sha512.0b7f8b98060031904c017e3a41eb187a16d40eeb829b95c4f8cb03681761fc4ab53dd219115b9b447f4dce1a05a214764461e7d3703392a9f32f9511ce8c86c8",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build:css": "tailwindcss -i ./src/styles/main.css -o ./public/css/main.css --minify",
    "watch:css": "tailwindcss -i ./src/styles/main.css -o ./public/css/main.css --watch",
    "build:ts": "tsc",
    "vendor:sync": "node scripts/vendor-assets.mjs",
    "build": "pnpm run vendor:sync && pnpm run build:css && pnpm run build:ts",
    "vercel-build": "pnpm run build",
    "start": "node dist/server.js",
    "preview": "pnpm run build && pnpm run start",
    "dev:server": "tsx watch src/server.ts",
    "dev": "npm-run-all --parallel watch:css dev:server",
    "typecheck": "tsc --noEmit && pnpm run typecheck:tests",
    "typecheck:tests": "tsc -p tsconfig.test.json --noEmit",
    "test": "tsx --test tests/**/*.test.ts",
    "lint": "biome check .",
    "fix": "biome check --write .",
    "format": "biome format --write .",
    "verify": "pnpm run typecheck && pnpm run test && pnpm run lint && pnpm run build",
    "prepare": "simple-git-hooks && node scripts/vendor-assets.mjs"
  },
  "dependencies": {
    "@resvg/resvg-js": "2.6.2",
    "@tailwindcss/cli": "4.3.2",
    "@types/express": "5.0.6",
    "@types/node": "24.13.3",
    "@types/pug": "2.0.10",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "express-rate-limit": "8.5.2",
    "gsap": "3.15.0",
    "helmet": "8.2.0",
    "htmx.org": "2.0.10",
    "pug": "3.0.4",
    "resend": "6.17.2",
    "satori": "0.26.0",
    "tailwindcss": "4.3.2",
    "typescript": "6.0.3",
    "wawoff2": "2.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "npm-run-all": "4.1.5",
    "simple-git-hooks": "2.13.1",
    "tsx": "4.23.0"
  },
  "simple-git-hooks": {
    "pre-push": "pnpm install --frozen-lockfile --lockfile-only || (echo 'Lockfile out of sync. Run pnpm install.' && exit 1) && pnpm run typecheck && pnpm test"
  }
}
