{
  "name": "umais-ali",
  "version": "2.4.1",
  "private": true,
  "description": "Umais Ali — SEO Executive portfolio (Node + Express + Pug + HTMX + Tailwind).",
  "main": "dist/server.js",
  "packageManager": "pnpm@10.18.2",
  "pnpm": {
    "onlyBuiltDependencies": ["@parcel/watcher", "esbuild"]
  },
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "build:css": "tailwindcss -i ./src/styles/main.css -o ./public/css/main.css --minify",
    "watch:css": "tailwindcss -i ./src/styles/main.css -o ./public/css/main.css --watch",
    "build:ts": "tsc",
    "build": "pnpm run build:css && pnpm run build:ts",
    "vercel-build": "pnpm run build",
    "start": "node dist/server.js",
    "dev:server": "tsx watch src/server.ts",
    "dev": "npm-run-all --parallel watch:css dev:server",
    "typecheck:tests": "tsc -p tsconfig.test.json",
    "test": "tsx --test tests/**/*.test.ts"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/cli": "^4.2.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/pug": "^2.0.10",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.1.0",
    "pug": "^3.0.3",
    "resend": "^6.12.2",
    "satori": "^0.26.0",
    "tailwindcss": "^4.2.0",
    "typescript": "^6.0.3",
    "wawoff2": "^2.0.1"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "tsx": "^4.19.2"
  }
}
