{
  "name": "umais-ali",
  "version": "3.1.6",
  "private": true,
  "type": "module",
  "description": "Umais Ali: SEO Executive portfolio (Astro + Svelte 5 + Tailwind CSS 4).",
  "packageManager": "pnpm@11.17.0+sha512.cca3cea332ad254bb84145f966d19f4879615210346fc92c79a047f23a0d7b3cca3c3792f0076ba1f1831d277efbcf0a9119b31a9a60eca7fb3d6231f331ef72",
  "engines": {
    "node": ">=24.x"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "sync": "astro sync",
    "typecheck": "astro check && pnpm run typecheck:tests",
    "typecheck:tests": "tsc -p tsconfig.test.json --noEmit",
    "test": "NODE_ENV=test tsx --import ./tests/support/register-loaders.mjs --test tests/**/*.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "lint": "biome check .",
    "audit": "pnpm audit --audit-level high",
    "fix": "biome check --write .",
    "format": "biome format --write .",
    "verify": "pnpm run sync && pnpm run typecheck && pnpm run test && pnpm run lint && pnpm run build",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@astrojs/sitemap": "3.7.3",
    "@astrojs/svelte": "9.0.1",
    "@astrojs/vercel": "11.0.3",
    "@resvg/resvg-js": "2.6.2",
    "@tailwindcss/vite": "4.3.3",
    "@types/node": "24.13.3",
    "astro": "7.1.3",
    "dotenv": "17.4.2",
    "motion": "12.42.2",
    "resend": "6.18.0",
    "satori": "0.29.0",
    "svelte": "5.56.7",
    "tailwindcss": "4.3.3",
    "typescript": "6.0.3",
    "wawoff2": "2.0.1"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@biomejs/biome": "2.5.5",
    "@playwright/test": "1.61.1",
    "simple-git-hooks": "2.13.1",
    "tsx": "4.23.1"
  },
  "simple-git-hooks": {
    "pre-push": "pnpm install --frozen-lockfile --lockfile-only || (echo 'Lockfile out of sync. Run pnpm install.' && exit 1) && pnpm run typecheck && pnpm test"
  }
}
