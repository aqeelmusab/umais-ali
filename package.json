{
  "name": "umais-ali",
  "version": "2.4.2",
  "private": true,
  "description": "Umais Ali — SEO Executive portfolio (Node + Express + Pug + HTMX + Tailwind).",
  "main": "dist/server.js",
  "packageManager": "pnpm@11.2.2+sha512.36e6621fad506178936455e70247b8808ef4ec25797a9f437a93281a020484e2607f6a469a22e982987c3dbb8866e3071514ab10a4a1749e06edcd1ec118436f",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build:css": "tailwindcss -i ./src/styles/main.css -o ./public/css/main.css --minify",
    "watch:css": "tailwindcss -i ./src/styles/main.css -o ./public/css/main.css --watch",
    "build:ts": "tsc",
    "build": "pnpm run build:css && pnpm run build:ts",
    "vercel-build": "pnpm run build",
    "start": "node dist/server.js",
    "preview": "pnpm run build && pnpm run start",
    "dev:server": "tsx watch src/server.ts",
    "dev": "npm-run-all --parallel watch:css dev:server",
    "typecheck": "tsc --noEmit && pnpm run typecheck:tests",
    "typecheck:tests": "tsc -p tsconfig.test.json --noEmit",
    "test": "tsx --test tests/**/*.test.ts",
    "lint": "biome check .",
    "fix": "biome check --write .",
    "format": "biome format --write .",
    "verify": "pnpm run typecheck && pnpm run test && pnpm run lint && pnpm run build",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/cli": "^4.3.0",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.4",
    "@types/pug": "^2.0.10",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "pug": "^3.0.4",
    "resend": "^6.12.4",
    "satori": "^0.26.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "wawoff2": "^2.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "npm-run-all": "^4.1.5",
    "simple-git-hooks": "^2.13.1",
    "tsx": "^4.22.4"
  },
  "simple-git-hooks": {
    "pre-push": "pnpm install --frozen-lockfile --lockfile-only || (echo 'Lockfile out of sync. Run pnpm install.' && exit 1) && pnpm run typecheck && pnpm test"
  }
}
