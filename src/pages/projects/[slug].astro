---
import { Image } from 'astro:assets'
import Footer from '../../components/layout/Footer.astro'
import Header from '../../components/layout/Header.astro'
import Icon from '../../components/layout/Icon.astro'
import ScrollToTop from '../../components/layout/ScrollToTop.astro'
import { projects } from '../../data/projects'
import BaseLayout from '../../layouts/BaseLayout.astro'
import { createProjectGraph } from '../../lib/seo/structured-data'

export function getStaticPaths() {
  return projects.map((project, index) => {
    const prevProject = index > 0 ? projects[index - 1] : null
    const nextProject = index < projects.length - 1 ? projects[index + 1] : null
    return {
      params: { slug: project.slug },
      props: { project, prevProject, nextProject },
    }
  })
}

const { project, prevProject, nextProject } = Astro.props

const jsonLd = createProjectGraph(project)
---
<BaseLayout
  title={`${project.title} - ${project.category} Case Study | Umais Ali`}
  description={project.description}
  canonicalPath={`/projects/${project.slug}`}
  jsonLd={jsonLd}
>
  <Header />

  <main id="main" class="relative min-h-screen px-6 pt-32 pb-24 md:px-12 md:pt-40 lg:px-20">
    <div class="pointer-events-none absolute inset-0" aria-hidden="true">
      <div class="hero-wash absolute rounded-full left-1/2 top-0 -translate-x-1/2 h-160 w-275 opacity-40"></div>
      <div class="hero-grid-bg absolute inset-0 opacity-[0.04]"></div>
    </div>

    <div class="relative mx-auto max-w-6xl">
      {/* Breadcrumb / Category Row */}
      <nav class="flex items-center font-mono uppercase text-ink-muted gap-2 text-[0.65rem] tracking-[0.22em] mb-8" aria-label="Breadcrumb">
        <a class="transition-colors hover:text-ink" href="/">Home</a>
        <span>/</span>
        <span class="text-brand" aria-current="page">0{project.id} · {project.year}</span>
      </nav>

      {/* Main Grid Block */}
      <div class="rounded-xl border border-line bg-surface-raised/40 overflow-hidden shadow-xl">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-0">

          {/* LEFT: visual + title details */}
          <div class="relative flex flex-col bg-surface-raised lg:col-span-7 border-b border-line lg:border-b-0 lg:border-r">
            <div class="relative aspect-video w-full overflow-hidden bg-surface-muted">
              <Image class="h-full w-full object-cover animate-fade-in" src={project.image} alt={project.title} widths={[480, 768, 1024]} sizes="(min-width: 1024px) 58vw, 100vw" format="webp" quality={70} loading="eager" fetchpriority="high" decoding="async" />
              <div class="absolute inset-0 bg-linear-to-t from-surface/80 via-transparent to-transparent" aria-hidden="true"></div>
            </div>
            <div class="flex flex-col gap-4 p-6 md:p-10">
              <h1 class="font-serif text-ink text-3xl md:text-5xl tracking-[-0.02em] leading-[1.05]">
                {project.title}.
                <br />
                <span class="serif-italic text-ink-muted">{project.description}</span>
              </h1>
              {project.result && (
                <div class="inline-flex items-center self-start rounded-full border border-brand font-mono uppercase text-brand gap-2 bg-brand/8 px-3 py-1.5 text-[0.7rem] tracking-[0.22em]">
                  <span class="relative inline-flex h-1.5 w-1.5">
                    <span class="absolute inline-flex animate-pulse-soft rounded-full bg-brand h-full w-full"></span>
                    <span class="relative inline-flex rounded-full bg-brand h-1.5 w-1.5"></span>
                  </span>
                  <span>{project.result}</span>
                </div>
              )}
            </div>
          </div>

          {/* RIGHT: narrative + specifications sidebar */}
          <div class="flex flex-col lg:col-span-5">
            {/* Narrative */}
            <div class="flex flex-col border-b border-line gap-4 p-6 md:p-10">
              <span class="eyebrow">The story</span>
              <p class="text-ink-muted text-base leading-relaxed">{project.longDescription}</p>
            </div>

            {/* Meta specs sheet */}
            <dl class="grid grid-cols-2 bg-line gap-px">
              <div class="flex flex-col bg-surface gap-1 p-6 md:p-8">
                <dt class="font-mono uppercase text-ink-muted text-[0.65rem] tracking-[0.22em]">Client</dt>
                <dd class="font-serif text-ink mt-1 text-lg tracking-[-0.01em]">{project.client}</dd>
              </div>
              <div class="flex flex-col bg-surface gap-1 p-6 md:p-8">
                <dt class="font-mono uppercase text-ink-muted text-[0.65rem] tracking-[0.22em]">Year</dt>
                <dd class="font-serif text-ink mt-1 text-lg tracking-[-0.01em]">{project.year}</dd>
              </div>
              <div class="flex flex-col bg-surface gap-1 p-6 md:p-8">
                <dt class="font-mono uppercase text-ink-muted text-[0.65rem] tracking-[0.22em]">My role</dt>
                <dd class="font-serif text-ink mt-1 text-lg tracking-[-0.01em]">{project.role}</dd>
              </div>
              <div class="flex flex-col bg-surface gap-1 p-6 md:p-8">
                <dt class="font-mono uppercase text-ink-muted text-[0.65rem] tracking-[0.22em]">Focus</dt>
                <dd class="font-serif text-ink mt-1 text-lg tracking-[-0.01em]">{project.category}</dd>
              </div>
            </dl>

            {/* Tags list */}
            <div class="flex flex-col border-t border-line gap-3 p-6 md:p-10">
              <span class="eyebrow">What it took</span>
              <ul class="flex flex-wrap gap-2">
                {project.tags.map((tag) => (
                  <li class="inline-flex items-center rounded-full border border-line font-mono text-ink-muted bg-surface-raised/40 px-3 py-1 text-[0.7rem]">{tag}</li>
                ))}
              </ul>
            </div>

            {/* Links and Footer Navigation */}
            <div class="mt-auto border-t border-line p-6 md:p-10 flex flex-col gap-6">
              <div class="flex items-center justify-between gap-4">
                {prevProject ? (
                  <a href={`/projects/${prevProject.slug}`} class="font-mono text-ink-muted hover:text-ink text-xs uppercase tracking-[0.18em] flex items-center gap-2 transition-colors">
                    <Icon name="arrow-left" class="h-4 w-4" /> Prev Case
                  </a>
                ) : (
                  <span class="opacity-25 font-mono text-ink-muted text-xs uppercase tracking-[0.18em] flex items-center gap-2 cursor-not-allowed">
                    <Icon name="arrow-left" class="h-4 w-4" /> Boundary
                  </span>
                )}

                {nextProject ? (
                  <a href={`/projects/${nextProject.slug}`} class="font-mono text-ink-muted hover:text-ink text-xs uppercase tracking-[0.18em] flex items-center gap-2 transition-colors">
                    Next Case <Icon name="arrow-right" class="h-4 w-4" />
                  </a>
                ) : (
                  <span class="opacity-25 font-mono text-ink-muted text-xs uppercase tracking-[0.18em] flex items-center gap-2 cursor-not-allowed">
                    Boundary <Icon name="arrow-right" class="h-4 w-4" />
                  </span>
                )}
              </div>

              <div class="border-t border-line/80 pt-6 flex justify-center">
                <a class="group inline-flex items-center rounded-full bg-ink font-medium text-surface transition-all duration-300 gap-3 h-12 px-6 text-sm hover:bg-ink/90 active:scale-[0.98]" href="/#contact">
                  <span>Start something like this</span>
                  <Icon name="arrow-up-right" class="h-3.5 w-3.5" />
                </a>
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </main>

  <Footer />
  <ScrollToTop />

  <script>
    import { initPageInteractions } from '../../scripts/page';
    import { initAnimations } from '../../scripts/animations';

    initPageInteractions();
    initAnimations();
  </script>
</BaseLayout>
