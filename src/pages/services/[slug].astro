---
import Footer from '../../components/layout/Footer.astro'
import Header from '../../components/layout/Header.astro'
import Icon from '../../components/layout/Icon.astro'
import ScrollToTop from '../../components/layout/ScrollToTop.astro'
import Contact from '../../components/sections/Contact.astro'
import { sectionHref, services } from '../../data/site'
import BaseLayout from '../../layouts/BaseLayout.astro'
import { createServiceGraph } from '../../lib/seo/structured-data'

export function getStaticPaths() {
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }))
}

const { service } = Astro.props

const relatedServices = services.filter((candidate) =>
  service.relatedSlugs.includes(candidate.slug),
)

const jsonLd = createServiceGraph(service)
---
<BaseLayout
  title={service.metaTitle}
  description={service.metaDescription}
  canonicalPath={`/services/${service.slug}`}
  jsonLd={jsonLd}
>
  <Header />

  <main id="main">
    <section id="top" class="relative overflow-hidden px-6 pt-32 pb-20 md:px-12 md:pt-44 md:pb-28 lg:px-20">
      <div class="pointer-events-none absolute inset-0" aria-hidden="true">
        <div class="hero-wash absolute rounded-full left-1/2 top-0 -translate-x-1/2 h-160 w-275 opacity-60"></div>
        <div class="hero-grid-bg absolute inset-0 opacity-[0.06]"></div>
      </div>

      <div class="relative mx-auto max-w-6xl">
        <nav class="flex items-center font-mono uppercase text-ink-muted animate-fade-up gap-2 text-[0.65rem] tracking-[0.22em]" aria-label="Breadcrumb">
          <a class="transition-colors hover:text-ink" href="/services">Services</a>
          <span>/</span>
          <span class="text-brand">{service.number}</span>
        </nav>

        <div class="grid grid-cols-1 mt-10 gap-12 lg:grid-cols-12 lg:gap-16">
          <div class="flex flex-col lg:col-span-8">
            <span class="eyebrow animate-fade-up stagger-1">{service.hero.eyebrow}</span>
            <h1 class="font-serif text-ink animate-fade-up stagger-2 mt-8 text-[clamp(2.75rem,7.6vw,6rem)] leading-[0.94] tracking-tight">
              {service.hero.lineOne}
              <br />
              <span class="serif-italic text-spotlight">{service.hero.accent}</span>
            </h1>
            <p class="text-ink-muted animate-fade-up stagger-3 mt-8 max-w-2xl text-base md:text-lg leading-relaxed">{service.hero.intro}</p>
            <div class="flex flex-wrap items-center animate-fade-up stagger-4 mt-10 gap-4">
              <a class="hover-glow group inline-flex items-center rounded-full bg-ink font-medium text-surface transition-all duration-300 gap-2 h-12 pl-6 pr-5 text-sm hover:bg-ink/90 active:scale-[0.98]" href={sectionHref('contact')}>
                Talk about this
                <span class="inline-flex transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5">
                  <Icon name="arrow-up-right" class="h-4 w-4" />
                </span>
              </a>
              <a class="group inline-flex items-center rounded-full border border-line font-medium text-ink transition-colors duration-300 gap-2 h-12 px-6 text-sm hover:border-ink/40 hover:bg-ink/3" href="/services">
                All services
                <span class="inline-flex transition-transform duration-300 group-hover:translate-x-0.5">
                  <Icon name="arrow-right" class="h-4 w-4" />
                </span>
              </a>
            </div>
          </div>

          <aside class="flex flex-col justify-end lg:col-span-4">
            <div class="rounded-lg border border-line animate-fade-up stagger-3 bg-surface-raised/50 p-6 md:p-8">
              <div class="flex items-center justify-between gap-4">
                <span class="font-mono text-brand text-xs tracking-[0.18em]">{service.number}</span>
                <span class="font-mono uppercase text-ink-muted text-[0.65rem] tracking-[0.22em]">Scope</span>
              </div>
              <h2 class="font-serif text-ink mt-6 text-2xl tracking-[-0.015em] leading-tight">Who this is for</h2>
              <ul class="flex flex-col border-t border-line mt-6 gap-3 pt-6">
                {service.bestFor.map((item) => (
                  <li class="flex items-start text-ink-muted gap-3 text-sm leading-relaxed">
                    <span class="inline-flex shrink-0 items-center justify-center rounded-full bg-brand text-brand-ink mt-0.5 h-5 w-5">
                      <Icon name="check" class="h-3 w-3" />
                    </span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
              <dl class="grid grid-cols-1 border-t border-line mt-7 gap-5 pt-7">
                <div>
                  <dt class="font-mono uppercase text-ink-muted text-[0.65rem] tracking-[0.2em]">Timeline</dt>
                  <dd class="text-ink mt-2 text-sm leading-relaxed">{service.scope.timeline}</dd>
                </div>
                <div>
                  <dt class="font-mono uppercase text-ink-muted text-[0.65rem] tracking-[0.2em]">Format</dt>
                  <dd class="text-ink mt-2 text-sm leading-relaxed">{service.scope.format}</dd>
                </div>
              </dl>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <section class="relative px-6 py-24 md:px-12 md:py-32 lg:px-20">
      <div class="mx-auto grid grid-cols-1 max-w-6xl gap-12 lg:grid-cols-12 lg:gap-16">
        <div class="flex flex-col lg:col-span-4">
          <span class="eyebrow">Why it matters</span>
          <h2 class="font-serif text-ink mt-6 text-4xl md:text-5xl tracking-tight leading-[1.05]">
            The work behind
            <br />
            <span class="serif-italic text-spotlight-soft">the recommendation.</span>
          </h2>
        </div>
        <div class="flex flex-col text-ink-muted lg:col-span-8 gap-5 text-base md:text-lg leading-relaxed">
          {service.overview.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </div>
      </div>
    </section>

    <section class="relative border-y border-line px-6 py-20 md:px-12 md:py-24 lg:px-20 bg-surface-raised/20">
      <div class="mx-auto max-w-6xl">
        <div class="flex flex-col border-b border-line gap-6 pb-12 md:flex-row md:items-end md:justify-between">
          <div>
            <span class="eyebrow">Outcomes</span>
            <h2 class="font-serif text-ink mt-6 text-4xl md:text-5xl tracking-tight leading-[1.05]">
              What gets
              <br />
              <span class="serif-italic text-spotlight-soft">clearer.</span>
            </h2>
          </div>
          <p class="text-ink-muted max-w-md text-sm md:text-base leading-relaxed">{service.scope.handoff}</p>
        </div>

        <ul class="grid grid-cols-1 bg-line gap-px mt-px md:grid-cols-3">
          {service.outcomes.map((outcome, outcomeIndex) => (
            <li class="bg-surface p-8 lg:p-10">
              <span class="font-mono text-brand text-xs tracking-[0.18em]">0{outcomeIndex + 1}</span>
              <h3 class="font-serif text-ink mt-6 text-2xl tracking-[-0.015em] leading-tight">{outcome.title}</h3>
              <p class="text-ink-muted mt-4 text-sm leading-relaxed">{outcome.text}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section class="relative px-6 py-24 md:px-12 md:py-32 lg:px-20">
      <div class="mx-auto grid grid-cols-1 max-w-6xl gap-12 lg:grid-cols-12 lg:gap-16">
        <div class="flex flex-col lg:col-span-4">
          <span class="eyebrow">Process</span>
          <h2 class="font-serif text-ink mt-6 text-4xl md:text-5xl tracking-tight leading-[1.05]">
            A calm way
            <br />
            <span class="serif-italic text-spotlight-soft">to move.</span>
          </h2>
        </div>
        <div class="flex flex-col lg:col-span-8">
          <ol class="flex flex-col">
            {service.process.map((step, stepIndex) => {
              const borderClass = stepIndex === service.process.length - 1 ? 'border-b' : '';
              return (
                <li class={`grid grid-cols-1 border-t border-line gap-5 py-8 md:grid-cols-12 ${borderClass}`}>
                  <span class="font-mono text-brand text-xs tracking-[0.18em] md:col-span-2">0{stepIndex + 1}</span>
                  <div class="flex flex-col md:col-span-10">
                    <h3 class="font-serif text-ink text-2xl md:text-3xl tracking-[-0.015em] leading-tight">{step.title}</h3>
                    <p class="text-ink-muted mt-4 max-w-2xl text-sm md:text-base leading-relaxed">{step.text}</p>
                  </div>
                </li>
              );
            })}
          </ol>
        </div>
      </div>
    </section>

    <section class="relative border-y border-line px-6 py-20 md:px-12 md:py-24 lg:px-20 bg-surface-raised/20">
      <div class="mx-auto grid grid-cols-1 max-w-6xl gap-10 lg:grid-cols-12 lg:gap-16">
        <div class="flex flex-col lg:col-span-5">
          <span class="eyebrow">Deliverables</span>
          <h2 class="font-serif text-ink mt-6 text-4xl md:text-5xl tracking-tight leading-[1.05]">
            Practical assets,
            <br />
            <span class="serif-italic text-spotlight-soft">not shelfware.</span>
          </h2>
          <p class="text-ink-muted mt-6 max-w-md text-sm md:text-base leading-relaxed">
            The final handoff is built for implementation. It should be clear enough for leadership to understand and specific enough for the people doing the work.
          </p>
        </div>
        <div class="grid grid-cols-1 gap-px bg-line lg:col-span-7 md:grid-cols-3">
          {service.deliverables.map((item) => (
            <div class="bg-surface p-7">
              <span class="inline-flex items-center justify-center rounded-full bg-brand text-brand-ink h-8 w-8">
                <Icon name="check" class="h-4 w-4" />
              </span>
              <h3 class="font-serif text-ink mt-6 text-2xl tracking-[-0.015em] leading-tight">{item}</h3>
              <p class="text-ink-muted mt-3 text-sm leading-relaxed">Included in the plan, explained in the handoff, and tied back to the business reason for doing it.</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {relatedServices.length > 0 && (
      <section class="relative px-6 py-24 md:px-12 md:py-32 lg:px-20">
        <div class="mx-auto max-w-6xl">
          <div class="flex flex-col border-b border-line gap-6 pb-12 md:flex-row md:items-end md:justify-between">
            <div>
              <span class="eyebrow">Related services</span>
              <h2 class="font-serif text-ink mt-6 text-4xl md:text-5xl tracking-tight leading-[1.05]">
                Work that often
                <br />
                <span class="serif-italic text-spotlight-soft">connects to this.</span>
              </h2>
            </div>
            <a class="group inline-flex items-center rounded-full border border-line font-medium text-ink transition-colors duration-300 gap-2 h-11 px-5 text-sm hover:border-ink/40 hover:bg-surface-raised" href="/services">
              View all services
              <span class="inline-flex transition-transform duration-300 group-hover:translate-x-0.5">
                <Icon name="arrow-right" class="h-4 w-4" />
              </span>
            </a>
          </div>

          <ul class="grid grid-cols-1 bg-line gap-px mt-px md:grid-cols-2">
            {relatedServices.map((related) => (
              <li class="bg-surface">
                <a class="group flex h-full flex-col transition-colors duration-300 gap-6 p-8 lg:p-10 hover:bg-surface-raised" href={`/services/${related.slug}`}>
                  <div class="flex items-start justify-between">
                    <span class="font-mono text-ink-muted text-xs tracking-[0.18em]">{related.number}</span>
                    <span class="inline-flex h-8 w-8 items-center justify-center rounded-full text-ink-muted transition-all duration-300 border border-transparent group-hover:border-line group-hover:text-ink group-hover:-rotate-12">
                      <Icon name="arrow-up-right" class="h-3.5 w-3.5" />
                    </span>
                  </div>
                  <h3 class="font-serif text-ink text-2xl tracking-[-0.02em] leading-tight">{related.title}</h3>
                  <p class="text-ink-muted leading-relaxed text-sm">{related.summary}</p>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )}

    <Contact />
  </main>

  <Footer />
  <ScrollToTop />

  <script>
    import { initPageInteractions } from '../../scripts/page';
    import { initAnimations } from '../../scripts/animations';

    initPageInteractions();
    initAnimations();
  </script>
</BaseLayout>
