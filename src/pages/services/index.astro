---
import Footer from '../../components/layout/Footer.astro'
import Header from '../../components/layout/Header.astro'
import Icon from '../../components/layout/Icon.astro'
import ScrollToTop from '../../components/layout/ScrollToTop.astro'
import Contact from '../../components/sections/Contact.astro'
import { sectionHref, services } from '../../data/site'
import BaseLayout from '../../layouts/BaseLayout.astro'
import { createSiteGraph } from '../../lib/seo/structured-data'

const jsonLd = createSiteGraph()
---
<BaseLayout
  title="SEO Services | Umais Ali"
  description="SEO services for teams that need technical audits, content strategy, programmatic SEO, link building, migrations, and reporting that turns search into a real growth channel."
  canonicalPath="/services"
  jsonLd={jsonLd}
>
  <Header />

  <main id="main">
    <section id="top" class="relative overflow-hidden px-6 pt-32 pb-20 md:px-12 md:pt-44 md:pb-28 lg:px-20">
      <div class="pointer-events-none absolute inset-0" aria-hidden="true">
        <div class="hero-wash absolute rounded-full left-1/2 top-0 -translate-x-1/2 h-160 w-275 opacity-60"></div>
        <div class="hero-grid-bg absolute inset-0 opacity-[0.06]"></div>
      </div>

      <div class="relative mx-auto max-w-6xl">
        <div class="grid grid-cols-1 gap-12 lg:grid-cols-12 lg:gap-16">
          <div class="flex flex-col lg:col-span-8">
            <span class="eyebrow">Services</span>
            <h1 class="font-serif text-ink animate-fade-up mt-8 text-[clamp(2.75rem,7.6vw,6rem)] leading-[0.94] tracking-tight">
              SEO services for teams
              <br />
              <span class="serif-italic text-spotlight">that need the work done properly.</span>
            </h1>
            <p class="text-ink-muted animate-fade-up stagger-1 mt-8 max-w-2xl text-base md:text-lg leading-relaxed">
              I work across technical SEO, content systems, authority building, migrations,
              programmatic pages, and reporting. Each service is built to turn search into
              an operating channel, not another folder of recommendations.
            </p>
            <div class="flex flex-wrap items-center animate-fade-up stagger-2 mt-10 gap-4">
              <a class="hover-glow group inline-flex items-center rounded-full bg-ink font-medium text-surface transition-all duration-300 gap-2 h-12 pl-6 pr-5 text-sm hover:bg-ink/90 active:scale-[0.98]" href={sectionHref('services-list')}>
                View services
                <span class="inline-flex transition-transform duration-300 group-hover:translate-y-0.5">
                  <Icon name="arrow-down" class="h-4 w-4" />
                </span>
              </a>
              <a class="group inline-flex items-center rounded-full border border-line font-medium text-ink transition-colors duration-300 gap-2 h-12 px-6 text-sm hover:border-ink/40 hover:bg-ink/3" href={sectionHref('contact')}>
                Start a project
                <span class="inline-flex transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5">
                  <Icon name="arrow-up-right" class="h-3.5 w-3.5" />
                </span>
              </a>
            </div>
          </div>

          <aside class="flex flex-col justify-end lg:col-span-4">
            <div class="rounded-lg border border-line bg-surface-raised/50 p-6 md:p-8">
              <span class="font-mono uppercase text-ink-muted text-[0.65rem] tracking-[0.22em]">Engagement style</span>
              <p class="font-serif text-ink mt-5 text-2xl tracking-[-0.015em] leading-tight">
                Clear diagnosis, focused execution, and calm reporting while the work moves.
              </p>
              <dl class="grid grid-cols-1 border-t border-line mt-8 gap-5 pt-6">
                <div>
                  <dt class="font-mono uppercase text-ink-muted text-[0.65rem] tracking-[0.2em]">Best fit</dt>
                  <dd class="text-ink mt-2 text-sm leading-relaxed">Growth teams, founders, and in house marketers who need SEO handled with care.</dd>
                </div>
                <div>
                  <dt class="font-mono uppercase text-ink-muted text-[0.65rem] tracking-[0.2em]">Availability</dt>
                  <dd class="text-ink mt-2 text-sm leading-relaxed">One or two projects at a time, so the work gets direct attention.</dd>
                </div>
              </dl>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <section id="services-list" class="relative px-6 py-24 md:px-12 md:py-32 lg:px-20">
      <div class="mx-auto max-w-6xl">
        <div class="flex flex-col border-b border-line gap-6 pb-12 md:flex-row md:items-end md:justify-between">
          <div>
            <span class="eyebrow">The work</span>
            <h2 class="font-serif text-ink mt-6 text-4xl md:text-5xl tracking-tight leading-[1.05]">
              Six ways to
              <br />
              <span class="serif-italic text-spotlight-soft">improve organic growth.</span>
            </h2>
          </div>
          <p class="text-ink-muted max-w-md text-sm md:text-base leading-relaxed">
            Most projects start with one service and expand once the highest impact work is clear.
            If the right answer is smaller than a retainer, I will say that too.
          </p>
        </div>

        <ul class="grid grid-cols-1 bg-line gap-px mt-px md:grid-cols-2 lg:grid-cols-3">
          {services.map((service) => (
            <li class="bg-surface">
              <a class="group flex h-full flex-col transition-colors duration-300 gap-6 p-8 lg:p-10 hover:bg-surface-raised" href={`/services/${service.slug}`}>
                <div class="flex items-start justify-between">
                  <span class="font-mono text-ink-muted text-xs tracking-[0.18em]">{service.number}</span>
                  <span class="inline-flex h-8 w-8 items-center justify-center rounded-full text-ink-muted transition-all duration-300 border border-transparent group-hover:border-line group-hover:text-ink group-hover:-rotate-12">
                    <Icon name="arrow-up-right" class="h-3.5 w-3.5" />
                  </span>
                </div>
                <h3 class="font-serif text-ink text-2xl tracking-[-0.02em] leading-tight">{service.title}</h3>
                <p class="text-ink-muted leading-relaxed text-sm">{service.summary}</p>
                <ul class="flex flex-col border-t border-line mt-auto gap-2 pt-4">
                  {service.deliverables.map((item) => (
                    <li class="flex items-center text-ink-muted gap-2 text-xs">
                      <span class="bg-brand h-px w-3 opacity-70"></span>
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section class="relative border-y border-line px-6 py-20 md:px-12 md:py-24 lg:px-20 bg-surface-raised/20">
      <div class="mx-auto grid grid-cols-1 max-w-6xl gap-10 lg:grid-cols-12 lg:gap-16">
        <div class="flex flex-col lg:col-span-4">
          <span class="eyebrow">How it usually starts</span>
          <h2 class="font-serif text-ink mt-6 text-4xl md:text-5xl tracking-tight leading-[1.05]">
            First, we find
            <br />
            <span class="serif-italic text-spotlight-soft">the real constraint.</span>
          </h2>
        </div>
        <ol class="grid grid-cols-1 gap-px bg-line lg:col-span-8 md:grid-cols-3">
          <li class="bg-surface p-7">
            <span class="font-mono text-brand text-xs tracking-[0.18em]">01</span>
            <h3 class="font-serif text-ink mt-6 text-2xl tracking-[-0.015em]">Diagnose</h3>
            <p class="text-ink-muted mt-3 text-sm leading-relaxed">We look at the site, the market, and the history before deciding what deserves effort.</p>
          </li>
          <li class="bg-surface p-7">
            <span class="font-mono text-brand text-xs tracking-[0.18em]">02</span>
            <h3 class="font-serif text-ink mt-6 text-2xl tracking-[-0.015em]">Prioritize</h3>
            <p class="text-ink-muted mt-3 text-sm leading-relaxed">The plan is ordered by impact, effort, risk, and the team that has to ship it.</p>
          </li>
          <li class="bg-surface p-7">
            <span class="font-mono text-brand text-xs tracking-[0.18em]">03</span>
            <h3 class="font-serif text-ink mt-6 text-2xl tracking-[-0.015em]">Execute</h3>
            <p class="text-ink-muted mt-3 text-sm leading-relaxed">We turn the strategy into shipped fixes, useful pages, clean reporting, and measured follow-through.</p>
          </li>
        </ol>
      </div>
    </section>

    <Contact />
  </main>

  <Footer />
  <ScrollToTop />

  <script>
    import { initPageInteractions } from '../../scripts/page';
    import { initAnimations } from '../../scripts/animations';

    initPageInteractions();
    initAnimations();
  </script>
</BaseLayout>
