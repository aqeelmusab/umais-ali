---
export interface Props {
  title?: string
  description?: string
  canonicalPath?: string
  canonicalUrl?: string
  socialImage?: string
  socialImageAlt?: string
  robots?: string
  googlebot?: string
  jsonLd?: unknown
}

import '../styles/global.css'
import { SITE_DESCRIPTION, SITE_NAME, SITE_TITLE, SITE_URL } from '../data/site'

const {
  title,
  description,
  canonicalPath,
  canonicalUrl,
  socialImage,
  socialImageAlt,
  robots,
  googlebot,
  jsonLd,
} = Astro.props as Props

const pageTitle = title || SITE_TITLE
const pageDescription = description || SITE_DESCRIPTION
const pageUrl = canonicalUrl || `${SITE_URL}${canonicalPath || '/'}`
const pageImage = socialImage || `${SITE_URL}/og-image.png`
const pageImageAlt = socialImageAlt || `${SITE_NAME} - SEO that actually moves the needle`
const robotsContent = robots || 'index, follow'
const googlebotContent =
  googlebot ||
  (robotsContent.includes('noindex')
    ? robotsContent
    : 'index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1')

const enableVercelInsights = import.meta.env.PROD
---
<!DOCTYPE html>
<html lang="en" class="bg-surface">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="application-name" content={SITE_NAME} />
    <meta name="apple-mobile-web-app-title" content={SITE_NAME} />
    <meta name="author" content={SITE_NAME} />
    <meta name="color-scheme" content="dark light" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="theme-color" content="#000000" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#fbf8f1" media="(prefers-color-scheme: light)" />

    <!-- Apply saved theme BEFORE first paint to avoid flash. -->
    <script is:inline src="/js/theme-init.js"></script>

    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="robots" content={robotsContent} />
    <meta name="googlebot" content={googlebotContent} />
    {!robotsContent.includes('noindex') && (
      <link rel="canonical" href={pageUrl} />
    )}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={pageImage} />
    <meta property="og:image:secure_url" content={pageImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={pageImageAlt} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@umaisali" />
    <meta name="twitter:creator" content="@umaisali" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={pageImage} />
    <meta name="twitter:image:alt" content={pageImageAlt} />

    <link rel="manifest" href="/favicons/site.webmanifest?v=2.4.2" />
    <link rel="icon" href="/favicons/favicon.svg?v=2.4.2" type="image/svg+xml" />
    <link rel="icon" href="/favicons/favicon-96x96.png?v=2.4.2" sizes="96x96" type="image/png" />
    <link rel="icon" href="/favicons/favicon.ico?v=2.4.2" />
    <link rel="apple-touch-icon" href="/favicons/apple-touch-icon.png?v=2.4.2" sizes="180x180" type="image/png" />

    <!-- Self-hosted fonts: preload critical subsets so above-the-fold typography paints immediately. -->
    <link rel="preload" href="/fonts/geist-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/instrument-serif-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/instrument-serif-italic-latin.woff2" as="font" type="font/woff2" crossorigin />

    {jsonLd && (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
  </head>
  <body class="font-sans antialiased overflow-x-hidden" tabindex="-1">
    <slot />

    {enableVercelInsights && (
      <script is:inline>
        window.va = window.va || function () { (window.vaq = window.vaq || []).push(arguments); };
      </script>
      <script is:inline src="/_vercel/insights/script.js" defer></script>
      <script is:inline>
        window.si = window.si || function () { (window.siq = window.siq || []).push(arguments); };
      </script>
      <script is:inline src="/_vercel/speed-insights/script.js" defer></script>
    )}
  </body>
</html>
