extends layout.pug

block content
  include partials/icons.pug
  include partials/header.pug

  main#main
    section#top.relative.overflow-hidden(class='px-6 pt-32 pb-20 md:px-12 md:pt-44 md:pb-28 lg:px-20')
      .pointer-events-none.absolute.inset-0(aria-hidden='true')
        .hero-wash.absolute.rounded-full(class='left-1/2 top-0 -translate-x-1/2 h-160 w-275 opacity-60')
        .hero-grid-bg.absolute.inset-0(class='opacity-[0.06]')

      .relative.mx-auto(class='max-w-6xl')
        nav.flex.items-center.font-mono.uppercase.text-muted-foreground.animate-fade-up(class='gap-2 text-[0.65rem] tracking-[0.22em]' aria-label='Breadcrumb')
          a.transition-colors(href='/services' class='hover:text-foreground') Services
          span /
          span.text-primary= service.number

        .grid.grid-cols-1(class='mt-10 gap-12 lg:grid-cols-12 lg:gap-16')
          .flex.flex-col(class='lg:col-span-8')
            span.eyebrow.animate-fade-up.stagger-1= service.hero.eyebrow
            h1.font-serif.text-foreground.animate-fade-up.stagger-2(class='mt-8 text-[clamp(2.75rem,7.6vw,6rem)] leading-[0.94] tracking-tight')
              = service.hero.lineOne
              br
              span.serif-italic.text-spotlight= service.hero.accent
            p.text-muted-foreground.animate-fade-up.stagger-3(class='mt-8 max-w-2xl text-base md:text-lg leading-relaxed')= service.hero.intro
            .flex.flex-wrap.items-center.animate-fade-up.stagger-4(class='mt-10 gap-4')
              a.hover-glow.group.inline-flex.items-center.rounded-full.bg-foreground.font-medium.text-background.transition-all.duration-300(
                href='#contact'
                class='gap-2 h-12 pl-6 pr-5 text-sm hover:bg-foreground/90 active:scale-[0.98]'
              )
                | Talk about this
                span.inline-flex.transition-transform.duration-300(class='group-hover:translate-x-0.5 group-hover:-translate-y-0.5')
                  +icon('arrow-up-right', 'h-4 w-4')
              a.group.inline-flex.items-center.rounded-full.border.border-border.font-medium.text-foreground.transition-colors.duration-300(
                href='/services'
                class='gap-2 h-12 px-6 text-sm hover:border-foreground/40 hover:bg-foreground/3'
              )
                | All services
                span.inline-flex.transition-transform.duration-300(class='group-hover:translate-x-0.5')
                  +icon('arrow-right', 'h-4 w-4')

          aside.flex.flex-col.justify-end(class='lg:col-span-4')
            .rounded-lg.border.border-border.animate-fade-up.stagger-3(class='bg-card/50 p-6 md:p-8')
              .flex.items-center.justify-between(class='gap-4')
                span.font-mono.text-primary(class='text-xs tracking-[0.18em]')= service.number
                span.font-mono.uppercase.text-muted-foreground(class='text-[0.65rem] tracking-[0.22em]') Scope
              h2.font-serif.text-foreground(class='mt-6 text-2xl tracking-[-0.015em] leading-tight') Who this is for
              ul.flex.flex-col.border-t.border-border(class='mt-6 gap-3 pt-6')
                each item in service.bestFor
                  li.flex.items-start.text-muted-foreground(class='gap-3 text-sm leading-relaxed')
                    span.inline-flex.shrink-0.items-center.justify-center.rounded-full.bg-primary.text-primary-foreground(class='mt-0.5 h-5 w-5')
                      +icon('check', 'h-3 w-3')
                    span= item
              dl.grid.grid-cols-1.border-t.border-border(class='mt-7 gap-5 pt-7')
                div
                  dt.font-mono.uppercase.text-muted-foreground(class='text-[0.65rem] tracking-[0.2em]') Timeline
                  dd.text-foreground(class='mt-2 text-sm leading-relaxed')= service.scope.timeline
                div
                  dt.font-mono.uppercase.text-muted-foreground(class='text-[0.65rem] tracking-[0.2em]') Format
                  dd.text-foreground(class='mt-2 text-sm leading-relaxed')= service.scope.format

    section.relative(class='px-6 py-24 md:px-12 md:py-32 lg:px-20')
      .mx-auto.grid.grid-cols-1(class='max-w-6xl gap-12 lg:grid-cols-12 lg:gap-16')
        .flex.flex-col(class='lg:col-span-4')
          span.eyebrow Why it matters
          h2.font-serif.text-foreground(class='mt-6 text-4xl md:text-5xl tracking-tight leading-[1.05]')
            | The work behind
            br
            span.serif-italic.text-muted-foreground the recommendation.
        .flex.flex-col.text-muted-foreground(class='lg:col-span-8 gap-5 text-base md:text-lg leading-relaxed')
          each paragraph in service.overview
            p= paragraph

    section.relative.border-y.border-border(class='px-6 py-20 md:px-12 md:py-24 lg:px-20 bg-card/20')
      .mx-auto(class='max-w-6xl')
        .flex.flex-col.border-b.border-border(class='gap-6 pb-12 md:flex-row md:items-end md:justify-between')
          div
            span.eyebrow Outcomes
            h2.font-serif.text-foreground(class='mt-6 text-4xl md:text-5xl tracking-tight leading-[1.05]')
              | What gets
              br
              span.serif-italic.text-muted-foreground clearer.
          p.text-muted-foreground(class='max-w-md text-sm md:text-base leading-relaxed')= service.scope.handoff

        ul.grid.grid-cols-1.bg-border(class='gap-px mt-px md:grid-cols-3')
          each outcome, outcomeIndex in service.outcomes
            li.bg-background(class='p-8 lg:p-10')
              span.font-mono.text-primary(class='text-xs tracking-[0.18em]') 0#{outcomeIndex + 1}
              h3.font-serif.text-foreground(class='mt-6 text-2xl tracking-[-0.015em] leading-tight')= outcome.title
              p.text-muted-foreground(class='mt-4 text-sm leading-relaxed')= outcome.text

    section.relative(class='px-6 py-24 md:px-12 md:py-32 lg:px-20')
      .mx-auto.grid.grid-cols-1(class='max-w-6xl gap-12 lg:grid-cols-12 lg:gap-16')
        .flex.flex-col(class='lg:col-span-4')
          span.eyebrow Process
          h2.font-serif.text-foreground(class='mt-6 text-4xl md:text-5xl tracking-tight leading-[1.05]')
            | A calm way
            br
            span.serif-italic.text-muted-foreground to move.
        .flex.flex-col(class='lg:col-span-8')
          ol.flex.flex-col
            each step, stepIndex in service.process
              - var borderClass = stepIndex === service.process.length - 1 ? 'border-b' : ''
              li.grid.grid-cols-1.border-t.border-border(class='gap-5 py-8 md:grid-cols-12 ' + borderClass)
                span.font-mono.text-primary(class='text-xs tracking-[0.18em] md:col-span-2') 0#{stepIndex + 1}
                .flex.flex-col(class='md:col-span-10')
                  h3.font-serif.text-foreground(class='text-2xl md:text-3xl tracking-[-0.015em] leading-tight')= step.title
                  p.text-muted-foreground(class='mt-4 max-w-2xl text-sm md:text-base leading-relaxed')= step.text

    section.relative.border-y.border-border(class='px-6 py-20 md:px-12 md:py-24 lg:px-20 bg-card/20')
      .mx-auto.grid.grid-cols-1(class='max-w-6xl gap-10 lg:grid-cols-12 lg:gap-16')
        .flex.flex-col(class='lg:col-span-5')
          span.eyebrow Deliverables
          h2.font-serif.text-foreground(class='mt-6 text-4xl md:text-5xl tracking-tight leading-[1.05]')
            | Practical assets,
            br
            span.serif-italic.text-muted-foreground not shelfware.
          p.text-muted-foreground(class='mt-6 max-w-md text-sm md:text-base leading-relaxed')
            | The final handoff is built for implementation. It should be clear enough for leadership to understand and specific enough for the people doing the work.
        .grid.grid-cols-1(class='gap-px bg-border lg:col-span-7 md:grid-cols-3')
          each item in service.deliverables
            .bg-background(class='p-7')
              span.inline-flex.items-center.justify-center.rounded-full.bg-primary.text-primary-foreground(class='h-8 w-8')
                +icon('check', 'h-4 w-4')
              h3.font-serif.text-foreground(class='mt-6 text-2xl tracking-[-0.015em] leading-tight')= item
              p.text-muted-foreground(class='mt-3 text-sm leading-relaxed') Included in the plan, explained in the handoff, and tied back to the business reason for doing it.

    if relatedServices.length
      section.relative(class='px-6 py-24 md:px-12 md:py-32 lg:px-20')
        .mx-auto(class='max-w-6xl')
          .flex.flex-col.border-b.border-border(class='gap-6 pb-12 md:flex-row md:items-end md:justify-between')
            div
              span.eyebrow Related services
              h2.font-serif.text-foreground(class='mt-6 text-4xl md:text-5xl tracking-tight leading-[1.05]')
                | Work that often
                br
                span.serif-italic.text-muted-foreground connects to this.
            a.group.inline-flex.items-center.rounded-full.border.border-border.font-medium.text-foreground.transition-colors.duration-300(
              href='/services'
              class='gap-2 h-11 px-5 text-sm hover:border-foreground/40 hover:bg-card'
            )
              | View all services
              span.inline-flex.transition-transform.duration-300(class='group-hover:translate-x-0.5')
                +icon('arrow-right', 'h-4 w-4')

          ul.grid.grid-cols-1.bg-border(class='gap-px mt-px md:grid-cols-2')
            each related in relatedServices
              li.bg-background
                a.group.flex.h-full.flex-col.transition-colors.duration-300(
                  href='/services/' + related.slug
                  class='gap-6 p-8 lg:p-10 hover:bg-card'
                )
                  .flex.items-start.justify-between
                    span.font-mono.text-muted-foreground(class='text-xs tracking-[0.18em]')= related.number
                    span.inline-flex.h-8.w-8.items-center.justify-center.rounded-full.text-muted-foreground.transition-all.duration-300(class='border border-transparent group-hover:border-border group-hover:text-foreground group-hover:-rotate-12')
                      +icon('arrow-up-right', 'h-3.5 w-3.5')
                  h3.font-serif.text-foreground(class='text-2xl tracking-[-0.02em] leading-tight')= related.title
                  p.text-muted-foreground.leading-relaxed(class='text-sm')= related.summary

    include partials/contact.pug

  include partials/footer.pug
  include partials/scroll-to-top.pug
