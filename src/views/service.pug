extends layout.pug

block content
  include partials/icons.pug
  include partials/header.pug

  main#top
    section.relative.overflow-hidden(class='px-6 pt-32 pb-20 md:px-12 md:pt-44 md:pb-28 lg:px-20')
      .pointer-events-none.absolute.inset-0(aria-hidden='true')
        .hero-wash.absolute.rounded-full(class='left-1/2 top-0 -translate-x-1/2 h-160 w-275 opacity-50')
        .hero-grid-bg.absolute.inset-0(class='opacity-[0.06]')

      .relative.mx-auto(class='max-w-6xl')
        .flex.flex-wrap.items-center.justify-between(class='gap-4')
          a.inline-flex.items-center.font-mono.uppercase.text-muted-foreground.transition-colors(
            href='/#services'
            class='gap-2 text-[0.65rem] tracking-[0.22em] hover:text-foreground'
          )
            +icon('arrow-left', 'h-3.5 w-3.5')
            span Services
          span.font-mono.uppercase.text-muted-foreground(class='text-[0.65rem] tracking-[0.22em]')= service.number

        .grid.grid-cols-1(class='mt-12 gap-12 lg:grid-cols-12 lg:gap-16')
          .flex.flex-col(class='lg:col-span-7')
            span.eyebrow= service.page.eyebrow
            h1.font-serif.text-foreground(class='mt-6 text-[clamp(2.75rem,7vw,5.8rem)] leading-[0.94] tracking-tight')= service.page.title
            p.text-muted-foreground(class='mt-8 max-w-2xl text-base md:text-lg leading-relaxed')= service.page.description
            .flex.flex-wrap.items-center(class='mt-10 gap-3')
              a.hover-glow.group.inline-flex.items-center.rounded-full.bg-foreground.font-medium.text-background.transition-all.duration-300(
                href='#contact'
                class='gap-2 h-12 pl-6 pr-5 text-sm hover:bg-foreground/90 active:scale-[0.98]'
              )
                span Talk through this service
                span.inline-flex.transition-transform.duration-300(class='group-hover:translate-x-0.5 group-hover:-translate-y-0.5')
                  +icon('arrow-up-right', 'h-4 w-4')
              a.inline-flex.items-center.rounded-full.border.border-border.font-medium.text-foreground.transition-colors.duration-300(
                href='/#work'
                class='gap-2 h-12 px-6 text-sm hover:border-foreground/40 hover:bg-foreground/3'
              )
                span See related work

          aside.flex.flex-col(class='lg:col-span-5')
            .service-panel.flex.flex-col(class='gap-6 p-6 md:p-8')
              span.font-mono.uppercase.text-primary(class='text-[0.65rem] tracking-[0.22em]') Best fit
              ul.flex.flex-col(class='gap-4')
                each item in service.page.bestFor
                  li.flex.items-start.text-muted-foreground(class='gap-3 text-sm leading-relaxed')
                    span.mt-2.h-px.w-4.shrink-0.bg-primary
                    span= item

    section.relative(class='px-6 py-20 md:px-12 md:py-28 lg:px-20')
      .mx-auto.grid.grid-cols-1(class='max-w-6xl gap-12 lg:grid-cols-12 lg:gap-16')
        .flex.flex-col(class='lg:col-span-4')
          span.eyebrow The work
          h2.font-serif.text-foreground(class='mt-6 text-4xl md:text-5xl tracking-tight leading-[1.05]')
            | What this
            br
            span.serif-italic.text-muted-foreground usually includes.
          p.text-muted-foreground(class='mt-6 text-sm md:text-base leading-relaxed')= service.page.intro

        .flex.flex-col(class='lg:col-span-8')
          ol.grid.grid-cols-1(class='gap-px bg-border md:grid-cols-3')
            each step, idx in service.page.process
              li.bg-background(class='p-6 md:p-8')
                span.font-mono.text-primary(class='text-[0.65rem] tracking-[0.22em]') 0#{idx + 1}
                h3.font-serif.text-foreground(class='mt-5 text-2xl tracking-[-0.02em] leading-tight')= step.title
                p.text-muted-foreground(class='mt-4 text-sm leading-relaxed')= step.body

    section.relative(class='px-6 py-20 md:px-12 md:py-28 lg:px-20')
      .mx-auto.grid.grid-cols-1(class='max-w-6xl gap-8 lg:grid-cols-2 lg:gap-12')
        .service-panel.flex.flex-col(class='gap-6 p-6 md:p-8')
          span.eyebrow What you get
          ul.grid.grid-cols-1(class='gap-4 sm:grid-cols-2')
            each item in service.page.outcomes
              li.flex.items-start.text-muted-foreground(class='gap-3 text-sm leading-relaxed')
                span.mt-1.inline-flex.h-5.w-5.shrink-0.items-center.justify-center.rounded-full.bg-primary.text-primary-foreground
                  +icon('check', 'h-3 w-3')
                span= item

        .service-panel.flex.flex-col(class='gap-6 p-6 md:p-8')
          span.eyebrow How we measure it
          .grid.grid-cols-2(class='gap-px bg-border')
            each metric in service.page.metrics
              .bg-background(class='p-5')
                span.font-mono.uppercase.text-muted-foreground(class='text-[0.65rem] tracking-[0.18em]')= metric

    section.relative(class='px-6 py-20 md:px-12 md:py-28 lg:px-20')
      .mx-auto(class='max-w-6xl')
        .flex.flex-col.border-b.border-border(class='gap-6 pb-10 md:flex-row md:items-end md:justify-between')
          div
            span.eyebrow Related services
            h2.font-serif.text-foreground(class='mt-6 text-4xl md:text-5xl tracking-tight leading-[1.05]')
              | Keep the
              br
              span.serif-italic.text-muted-foreground work connected.
          p.text-muted-foreground(class='max-w-md text-sm md:text-base leading-relaxed')
            | SEO gets stronger when technical, content, authority, and measurement work together. These are the adjacent areas I usually connect to this service.

        .grid.grid-cols-1(class='mt-10 gap-px bg-border md:grid-cols-3')
          each item in relatedServices
            a.group.bg-background.transition-colors.duration-300(
              href='/services/' + item.slug
              class='p-6 md:p-8 hover:bg-card'
            )
              .flex.items-start.justify-between(class='gap-6')
                span.font-mono.text-muted-foreground(class='text-xs tracking-[0.18em]')= item.number
                span.inline-flex.h-8.w-8.items-center.justify-center.rounded-full.text-muted-foreground.transition-all.duration-300(class='border border-transparent group-hover:border-border group-hover:text-foreground group-hover:-rotate-12')
                  +icon('arrow-up-right', 'h-3.5 w-3.5')
              h3.font-serif.text-foreground(class='mt-6 text-2xl tracking-[-0.02em] leading-tight')= item.title
              p.text-muted-foreground(class='mt-4 text-sm leading-relaxed')= item.summary

    include partials/contact.pug

  include partials/footer.pug
  include partials/scroll-to-top.pug
