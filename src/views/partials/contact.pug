include icons.pug

section#contact.relative.px-6.py-24.overflow-hidden(class='md:px-12 md:py-32 lg:px-20')
  .pointer-events-none.absolute.inset-0(aria-hidden='true')
    .absolute.top-0.rounded-full(class='left-1/2 -translate-x-1/2 h-125 w-200 bg-primary/8 blur-[120px]')

  .relative.z-10
    .mb-12.reveal
      .flex.items-center.gap-3.mb-4
        .h-px.w-8.bg-primary
        p.text-xs.font-semibold.tracking-widest.uppercase.text-primary Contact

    .grid.grid-cols-1.gap-12(class='md:grid-cols-12 md:gap-10')
      div(class='md:col-span-7')
        h2.font-serif.text-3xl.font-normal.tracking-tight.text-foreground.text-balance.reveal.stagger-1(class='sm:text-4xl md:text-5xl lg:text-6xl')
          | Need more traffic from Google?&nbsp;
          span.gradient-text Let's talk.
        p.mt-6.text-lg.leading-relaxed.text-muted-foreground.max-w-lg.reveal.stagger-2
          | Whether you need a full SEO strategy, a technical audit, or just a second opinion on your search performance, drop a note below and I'll get back to you.

        #contact-form-wrap.mt-10.max-w-xl.reveal.stagger-3
          include contact-form.pug

      .flex.flex-col.gap-10.justify-center(class='md:col-span-5')
        .reveal.stagger-4
          p.text-xs.font-medium.tracking-widest.uppercase.text-muted-foreground.mb-3 Email
          a.group.inline-flex.items-center.gap-2.text-lg.text-foreground.transition-colors(
            href='mailto:' + site.contactEmail
            class='hover:text-primary'
          )
            = site.contactEmail
            +icon('arrow-up-right', 'h-4 w-4 text-muted-foreground opacity-0 transition-all duration-300 group-hover:opacity-100 group-hover:text-primary group-hover:translate-x-0.5 group-hover:-translate-y-0.5')

        .reveal.stagger-5
          p.text-xs.font-medium.tracking-widest.uppercase.text-muted-foreground.mb-4 Social
          .flex.flex-col.gap-3
            each link in socialLinks
              a.group.inline-flex.items-center.gap-2.text-base.text-foreground.transition-colors(
                href=link.href
                target='_blank'
                rel='noopener noreferrer'
                class='hover:text-primary'
              )
                = link.label
                +icon('arrow-up-right', 'h-3.5 w-3.5 text-muted-foreground opacity-0 transition-all duration-300 group-hover:opacity-100 group-hover:text-primary group-hover:translate-x-0.5 group-hover:-translate-y-0.5')
                span.sr-only (opens in new tab)

        .flex.items-center.text-sm.text-muted-foreground.reveal.stagger-5(class='gap-2.5')
          span.relative.flex.h-2.w-2
            span.animate-pulse-soft.absolute.inline-flex.h-full.w-full.rounded-full.bg-emerald-400(class='opacity-75')
            span.relative.inline-flex.h-2.w-2.rounded-full.bg-emerald-400
          | Available for new projects
