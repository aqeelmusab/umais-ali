include icons.pug

section#contact.relative(class='px-6 py-24 md:px-12 md:py-32 lg:px-20')
  .mx-auto(class='max-w-6xl')
    .grid.grid-cols-1(class='gap-16 lg:grid-cols-12 lg:gap-20')

      //- LEFT — invitation
      .flex.flex-col(class='lg:col-span-5')
        span.eyebrow Get in touch
        h2.font-serif.text-foreground(class='mt-6 text-4xl md:text-5xl tracking-tight leading-[1.05]')
          | Got something
          br
          span.serif-italic.text-muted-foreground worth shipping?
        p.text-muted-foreground(class='mt-8 max-w-md text-base md:text-lg leading-relaxed')
          | Tell me a bit about your team, what you are stuck on,
          | and where you would like to be in twelve months. Most replies go out
          | within a day. Shorter notes are very welcome.

        .flex.flex-col(class='mt-12 gap-8')
          .flex.flex-col(class='gap-2')
            span.font-mono.uppercase.text-muted-foreground(class='text-[0.65rem] tracking-[0.22em]') Email
            a.group.inline-flex.items-center.font-serif.text-foreground.transition-colors(class='gap-2 text-xl hover:text-primary' href='mailto:' + site.contactEmail)
              span= site.contactEmail
              span.inline-flex.transition-transform.duration-300(class='translate-y-px group-hover:translate-x-0.5 group-hover:-translate-y-0.5')
                +icon('arrow-up-right', 'h-4 w-4')

          .flex.flex-col(class='gap-2')
            span.font-mono.uppercase.text-muted-foreground(class='text-[0.65rem] tracking-[0.22em]') Around the web
            ul.flex.flex-wrap(class='gap-x-4 gap-y-2')
              each link in socialLinks
                li
                  a.group.inline-flex.items-center.text-muted-foreground.transition-colors(class='gap-1 text-sm hover:text-foreground' href=link.href target='_blank' rel='noopener noreferrer')
                    span= link.label
                    span.inline-flex.transition-opacity.duration-300(class='opacity-0 group-hover:opacity-100')
                      +icon('arrow-up-right', 'h-3.5 w-3.5')

          .flex.items-center.border-t.border-border(class='gap-3 pt-8 mt-2')
            span.relative.inline-flex(class='h-2 w-2')
              span.absolute.inline-flex.animate-pulse-soft.rounded-full.bg-primary(class='h-full w-full')
              span.relative.inline-flex.rounded-full.bg-primary(class='h-2 w-2')
            span.font-mono.uppercase.text-muted-foreground(class='text-[0.65rem] tracking-[0.22em]') Currently taking work for July onwards

      //- RIGHT — form on a quiet card
      .flex.flex-col(class='lg:col-span-7')
        .rounded-lg.border.border-border(class='bg-card/40 p-6 md:p-10')
          #contact-form-wrap
            include contact-form.pug
