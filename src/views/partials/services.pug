include icons.pug

section#services.relative(class='px-6 py-24 md:px-12 md:py-32 lg:px-20')
  .mx-auto(class='max-w-6xl')
    .grid.grid-cols-1.border-b.border-border(class='gap-10 pb-12 lg:grid-cols-12 lg:gap-12')
      .flex.flex-col(class='lg:col-span-5')
        span.eyebrow How we'd work
        h2.font-serif.text-foreground(class='mt-6 text-4xl md:text-5xl tracking-[-0.025em] leading-[1.05]')
          | Six things
          br
          span.serif-italic.text-muted-foreground I'm good at.
      .flex.items-end(class='lg:col-span-7')
        p.text-muted-foreground(class='text-base md:text-lg leading-relaxed')
          | Most engagements start with one of these and grow from there.
          | If you need something that is not on the list, ask. I will tell you honestly
          | whether it is something I should be the one doing.

    ul.grid.grid-cols-1.bg-border(class='gap-px mt-px md:grid-cols-2 lg:grid-cols-3')
      each service in services
        li.group.relative.bg-background.transition-colors.duration-300(class='hover:bg-card')
          .flex.h-full.flex-col(class='gap-6 p-8 lg:p-10')
            .flex.items-start.justify-between
              span.font-mono.text-muted-foreground(class='text-xs tracking-[0.18em]')= service.number
              span.inline-flex.h-8.w-8.items-center.justify-center.rounded-full.text-muted-foreground.transition-all.duration-300(class='border border-transparent group-hover:border-border group-hover:text-foreground group-hover:rotate-[-12deg]')
                +icon('arrow-up-right', 'h-3.5 w-3.5')
            h3.font-serif.text-foreground(class='text-2xl tracking-[-0.02em] leading-tight')= service.title
            p.text-muted-foreground.leading-relaxed(class='text-sm')= service.summary
            ul.flex.flex-col.border-t.border-border(class='mt-auto gap-2 pt-4')
              each item in service.deliverables
                li.flex.items-center.text-muted-foreground(class='gap-2 text-xs')
                  span.bg-primary(class='h-px w-3 opacity-70')
                  span= item
