include logo.pug

footer.px-6.py-10(class='md:px-12 lg:px-20')
  .divider-gradient
  .flex.flex-col.gap-6.pt-8(class='sm:flex-row sm:flex-wrap sm:items-center sm:justify-between')
    .flex.items-center.gap-3
      +logo()
      span.text-xs.text-muted-foreground SEO Executive

    nav.flex.items-center.gap-5(class='sm:gap-6' aria-label='Footer navigation')
      each link in navLinks
        a.text-xs.text-muted-foreground.transition-colors.duration-300(href=link.href class='hover:text-foreground')= link.label

    p.text-xs.text-muted-foreground &copy; #{year} Umais Ali. All rights reserved.
