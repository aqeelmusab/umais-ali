include icons.pug

footer.relative.border-t.border-border(class='px-6 py-16 md:px-12 md:py-20 lg:px-20 bg-card/20')
  .mx-auto(class='max-w-6xl')

    .grid.grid-cols-1(class='gap-12 md:grid-cols-12')
      //- LEFT — wordmark + line
      .flex.flex-col(class='md:col-span-6 gap-4')
        - var footerLogoHref = currentPath && currentPath !== '/' ? '/' : '#top'
        a.inline-flex.items-baseline.font-serif.text-foreground(class='gap-1 text-2xl tracking-[-0.01em] hover:text-primary transition-colors' href=footerLogoHref)
          span Umais
          span.serif-italic.text-muted-foreground Ali
        p.text-muted-foreground(class='max-w-md text-sm leading-relaxed')
          | Built with care, served from Lahore. If something here looks broken, that
          | is on me. Send a note and I will fix it.

      //- RIGHT — link columns
      .grid.grid-cols-2(class='md:col-span-6 gap-8 md:grid-cols-3')
        nav.flex.flex-col(class='gap-3')
          span.font-mono.uppercase.text-muted-foreground(class='text-[0.65rem] tracking-[0.22em] mb-1') Site
          each link in navLinks
            - var footerHref = currentPath && currentPath !== '/' && link.href.charAt(0) === '#' ? '/' + link.href : link.href
            a.text-foreground.transition-colors(class='text-sm hover:text-primary' href=footerHref)= link.label

        nav.flex.flex-col(class='gap-3')
          span.font-mono.uppercase.text-muted-foreground(class='text-[0.65rem] tracking-[0.22em] mb-1') Elsewhere
          each link in socialLinks
            a.text-foreground.transition-colors(class='text-sm hover:text-primary' href=link.href target='_blank' rel='noopener noreferrer')= link.label

        .flex.flex-col(class='gap-3')
          span.font-mono.uppercase.text-muted-foreground(class='text-[0.65rem] tracking-[0.22em] mb-1') Direct
          a.text-foreground.transition-colors(class='text-sm hover:text-primary break-all' href='mailto:' + site.contactEmail)= site.contactEmail
          a.text-foreground.transition-colors(class='inline-flex items-center gap-1 text-sm hover:text-primary' href='#top')
            span Back to top
            +icon('arrow-up-right', 'h-3 w-3')

    .flex.flex-col.items-start.justify-between.border-t.border-border(class='gap-3 mt-14 pt-8 sm:flex-row sm:items-center')
      p.font-mono.text-muted-foreground(class='text-[0.7rem]') &copy; #{year} Umais Ali. All rights reserved.
      p.font-mono.uppercase.text-muted-foreground(class='text-[0.65rem] tracking-[0.22em]')
        | Lahore, PK · GMT+5
