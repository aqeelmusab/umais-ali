section#testimonials.relative(class='px-6 py-24 md:px-12 md:py-28 lg:px-20')
  .mx-auto(class='max-w-6xl')
    .flex.flex-col.border-b.border-border(class='gap-2 pb-10')
      span.eyebrow Kind words
      h2.font-serif.text-foreground(class='mt-6 text-4xl md:text-5xl tracking-[-0.025em] leading-[1.05]')
        | What people
        |
        span.serif-italic.text-muted-foreground actually said.

    .grid.grid-cols-1(class='mt-12 gap-px bg-border md:grid-cols-2')
      each t in testimonials
        figure.flex.flex-col.bg-background(class='gap-8 p-8 lg:p-12')
          span.font-serif.text-primary.leading-none(class='text-7xl' aria-hidden='true') &ldquo;
          blockquote.font-serif.text-foreground(class='text-xl md:text-2xl tracking-[-0.015em] leading-snug -mt-4')
            = t.quote
          figcaption.flex.items-center.border-t.border-border(class='gap-4 pt-6 mt-auto')
            span.inline-flex.items-center.justify-center.rounded-full.bg-card.font-serif.text-foreground.border.border-border(class='h-11 w-11 text-base')
              = t.author.split(' ').map(function (s) { return s.charAt(0) }).join('')
            .flex.flex-col.leading-tight
              span.text-foreground(class='text-sm font-medium')= t.author
              span.font-mono.text-muted-foreground(class='text-[0.7rem] mt-0.5')= t.role
