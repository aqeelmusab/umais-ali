mixin logo(extraClass)
  - var c = extraClass || ''
  span(class='flex items-center gap-1.5 ' + c)
    span.font-serif.text-base.font-medium.tracking-tight.text-foreground Umais
    span(class='text-primary/50 text-xs') &#x2022;
    span.font-serif.text-base.font-medium.tracking-tight.gradient-text Ali
