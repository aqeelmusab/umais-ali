mixin logo()
  a.group.inline-flex.items-center.gap-2(href='#top' aria-label='Umais Ali, home')
    span.relative.inline-flex.items-center.justify-center.overflow-hidden.rounded-md.border.border-border.bg-card.transition-colors(
      class='h-8 w-8 group-hover:border-primary/50'
    )
      span.font-serif.leading-none.text-foreground(class='text-base') UA
    span.flex.flex-col.leading-none
      span.font-serif.text-foreground(class='text-[0.95rem]') Umais Ali
      span.mt-1.font-mono.uppercase.text-muted-foreground(class='text-[0.55rem] tracking-[0.22em]') SEO Executive
