mixin logo(extraClass)
  - var c = extraClass || ''
  span(class='flex items-baseline gap-1 ' + c)
    span.font-sans.text-base.font-semibold.tracking-tight.text-foreground Umais
    span.serif-italic.gradient-text(class='text-lg leading-none') Ali
    span.relative.flex.h-1.w-1.self-center(aria-hidden='true')
      span.absolute.inline-flex.h-full.w-full.rounded-full.bg-primary(class='animate-pulse-soft opacity-80')
      span.relative.inline-flex.h-1.w-1.rounded-full.bg-primary
