include icons.pug

article.flex.flex-col(class='gap-0')
  //- Sticky header — index + category + close
  .sticky.top-0.z-10.flex.items-center.justify-between.border-b.border-border(
    class='gap-4 px-6 py-4 md:px-10 bg-card/85 backdrop-blur'
  )
    .flex.items-center(class='gap-3 min-w-0')
      span.font-mono.text-muted-foreground.shrink-0(class='text-[0.7rem] tracking-[0.18em]') 0#{project.id}
      span.h-px.flex-1.bg-border(class='max-w-[2rem]')
      span.font-mono.uppercase.text-foreground.truncate(class='text-[0.7rem] tracking-[0.22em]')= project.category
    button.group.inline-flex.items-center.justify-center.rounded-full.border.border-border.text-muted-foreground.transition-all.duration-300(
      type='button'
      data-modal-close
      aria-label='Close'
      class='h-9 w-9 hover:text-foreground hover:border-foreground/40 hover:rotate-90'
    )
      +icon('x', 'h-4 w-4')

  //- Main grid
  .grid.grid-cols-1(class='gap-0 lg:grid-cols-12')

    //- LEFT — visual + headline
    .relative.flex.flex-col.bg-card(class='lg:col-span-7 border-b border-border lg:border-b-0 lg:border-r')
      .relative.aspect-video.w-full.overflow-hidden(class='bg-muted')
        img.h-full.w-full.object-cover(src=project.image alt=project.title loading='lazy')
        .absolute.inset-0(class='bg-gradient-to-t from-background/80 via-background/0 to-transparent' aria-hidden='true')
      .flex.flex-col(class='gap-4 p-6 md:p-10')
        h2#project-modal-title.font-serif.text-foreground(class='text-3xl md:text-5xl tracking-[-0.025em] leading-[1.05]')
          = project.title + '. '
          span.serif-italic.text-muted-foreground= project.description
        if project.result
          .inline-flex.items-center.self-start.rounded-full.border.border-primary.font-mono.uppercase.text-primary(class='gap-2 bg-primary/[0.08] px-3 py-1.5 text-[0.7rem] tracking-[0.22em]')
            span.relative.inline-flex(class='h-1.5 w-1.5')
              span.absolute.inline-flex.animate-pulse-soft.rounded-full.bg-primary(class='h-full w-full')
              span.relative.inline-flex.rounded-full.bg-primary(class='h-1.5 w-1.5')
            span= project.result

    //- RIGHT — narrative + meta sidebar
    .flex.flex-col(class='lg:col-span-5')
      //- Narrative
      .flex.flex-col.border-b.border-border(class='gap-4 p-6 md:p-10')
        span.eyebrow The story
        p.text-muted-foreground(class='text-base leading-relaxed')= project.longDescription

      //- Meta rail
      dl.grid.grid-cols-2.bg-border(class='gap-px')
        .flex.flex-col.bg-background(class='gap-1 p-6 md:p-8')
          dt.font-mono.uppercase.text-muted-foreground(class='text-[0.65rem] tracking-[0.22em]') Client
          dd.font-serif.text-foreground(class='mt-1 text-lg tracking-[-0.01em]')= project.client
        .flex.flex-col.bg-background(class='gap-1 p-6 md:p-8')
          dt.font-mono.uppercase.text-muted-foreground(class='text-[0.65rem] tracking-[0.22em]') Year
          dd.font-serif.text-foreground(class='mt-1 text-lg tracking-[-0.01em]')= project.year
        .flex.flex-col.bg-background(class='gap-1 p-6 md:p-8')
          dt.font-mono.uppercase.text-muted-foreground(class='text-[0.65rem] tracking-[0.22em]') My role
          dd.font-serif.text-foreground(class='mt-1 text-lg tracking-[-0.01em]')= project.role
        .flex.flex-col.bg-background(class='gap-1 p-6 md:p-8')
          dt.font-mono.uppercase.text-muted-foreground(class='text-[0.65rem] tracking-[0.22em]') Focus
          dd.font-serif.text-foreground(class='mt-1 text-lg tracking-[-0.01em]')= project.category

      //- Tags
      .flex.flex-col.border-t.border-border(class='gap-3 p-6 md:p-10')
        span.eyebrow What it took
        ul.flex.flex-wrap(class='gap-2')
          each tag in project.tags
            li.inline-flex.items-center.rounded-full.border.border-border.font-mono.text-muted-foreground(class='bg-card/40 px-3 py-1 text-[0.7rem]')= tag

      //- CTA
      .mt-auto.border-t.border-border(class='p-6 md:p-10')
        a.group.inline-flex.items-center.rounded-full.bg-foreground.font-medium.text-background.transition-all.duration-300(
          href='#contact'
          data-modal-close
          class='gap-3 h-12 px-6 text-sm hover:bg-foreground/90 active:scale-[0.98]'
        )
          span Start something like this
          span.inline-flex.transition-transform.duration-300(class='group-hover:translate-x-0.5 group-hover:-translate-y-0.5')
            +icon('arrow-up-right', 'h-3.5 w-3.5')
