include icons.pug

mixin bentoCard(project, sizeClasses, isFeature)
  - var spanCls = sizeClasses || ''
  - var heightCls = isFeature ? 'min-h-[26rem] md:min-h-[34rem]' : 'min-h-[22rem] md:min-h-[26rem]'
  - var titleSizeCls = isFeature ? 'text-3xl md:text-5xl' : 'text-2xl md:text-3xl'
  article.bento-card.reveal.group(class=spanCls + ' ' + heightCls)
    button.relative.flex.h-full.w-full.flex-col.overflow-hidden.text-left(
      type='button'
      data-project-trigger
      data-project-id=project.id
      hx-get='/projects/' + project.id
      hx-target='#project-modal-content'
      hx-swap='innerHTML'
      aria-label='Open ' + project.title + ' case study'
    )
      //- Image fills the full card height (no aspect-ratio gap on narrow cards)
      img.bento-image.absolute.inset-0.h-full.w-full.object-cover(
        src=project.image
        alt=project.title
        loading='lazy'
        decoding='async'
      )
      //- Subtle vignette so text is always legible
      .project-vignette.pointer-events-none.absolute.inset-0(
        aria-hidden='true'
      )

      //- Top row: index + result
      .relative.z-10.flex.items-center.justify-between(class='p-5 lg:p-7')
        span.font-mono.uppercase.rounded-full.border(
          class='text-[0.65rem] tracking-[0.2em] backdrop-blur border-foreground/15 bg-background/40 px-2.5 py-1 text-foreground/85'
        ) 0#{project.id} · #{project.year}
        if project.result
          span.inline-flex.items-center.font-mono.uppercase.rounded-full.text-primary(
            class='gap-1.5 text-[0.65rem] tracking-[0.18em] border border-primary/30 bg-primary/8 px-2.5 py-1 backdrop-blur'
          )
            span.rounded-full.bg-primary.animate-pulse-soft(class='h-1.5 w-1.5')
            span= project.result

      //- Spacer fills remaining height so title sticks to the bottom
      .relative.flex-1

      //- Bottom title block
      .relative.z-10.flex.items-end.justify-between(class='gap-4 p-6 lg:p-8')
        .flex.flex-col(class='gap-2 min-w-0')
          span.font-mono.uppercase.text-muted-foreground(class='text-[0.65rem] tracking-[0.22em]')= project.category
          h3.font-serif.text-foreground(class= titleSizeCls + ' tracking-[-0.02em] leading-[1.05]')= project.title
          p.text-muted-foreground.line-clamp-2(class='hidden text-sm max-w-md ' + (isFeature ? 'lg:block mt-1' : ''))= project.description
        span.inline-flex.shrink-0.items-center.justify-center.rounded-full.border.text-foreground.transition-all.duration-300(
          class='h-11 w-11 border-foreground/15 bg-background/40 backdrop-blur group-hover:bg-foreground group-hover:text-background group-hover:border-transparent group-hover:-rotate-12'
        )
          +icon('arrow-up-right', 'h-4 w-4')

section#work.relative(class='px-6 py-24 md:px-12 md:py-32 lg:px-20')
  .mx-auto(class='max-w-6xl')
    //- Section header
    .flex.flex-col.border-b.border-border(class='gap-6 pb-12 md:flex-row md:items-end md:justify-between')
      div
        span.eyebrow Selected work
        h2.font-serif.text-foreground(class='mt-6 text-4xl md:text-5xl tracking-tight leading-[1.05]')
          | Five projects,
          br
          span.serif-italic.text-muted-foreground one common thread.
      .flex.flex-col(class='gap-3 max-w-md')
        p.text-muted-foreground(class='text-sm md:text-base')
          | Each one started with a team that had been told their SEO was fine.
          | It was not. Tap any case to read what we actually changed.
        span.font-mono.uppercase.text-muted-foreground(class='text-[0.65rem] tracking-[0.22em]')
          | 0#{projects.length} cases · 2024 to 2025

    //- Bento grid
    .grid.grid-cols-1(class='mt-12 gap-5 md:grid-cols-12 md:gap-6')
      +bentoCard(projects[0], 'md:col-span-7', false)
      +bentoCard(projects[1], 'md:col-span-5', false)
      +bentoCard(projects[2], 'md:col-span-6', false)
      +bentoCard(projects[3], 'md:col-span-6', false)
      +bentoCard(projects[4], 'md:col-span-12', true)
