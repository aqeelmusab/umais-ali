include icons.pug

section#about.relative(class='px-6 py-24 md:px-12 md:py-32 lg:px-20')
  .mx-auto(class='max-w-6xl')
    .grid.grid-cols-1(class='gap-12 lg:grid-cols-12 lg:gap-16')

      //- LEFT — narrative
      .flex.flex-col(class='lg:col-span-7')
        span.eyebrow About
        h2.font-serif.text-foreground(class='mt-6 text-4xl md:text-5xl tracking-tight leading-[1.05]')
          | A quiet executor
          br
          span.serif-italic.text-muted-foreground who likes the boring wins.
        .flex.flex-col.text-muted-foreground(class='mt-8 gap-5 text-base md:text-lg leading-relaxed')
          p
            | I have spent the past five years helping teams turn search from a
            | guessing game into a&nbsp;
            span.serif-italic.text-foreground reliable channel
            | . That has meant late nights in log files, painstaking redirect maps,
            | and a lot of rewriting product copy that nobody else wanted to touch.
          p
            | The work I am proud of does not look exciting on a slide. It looks like
            | a clean indexation chart, a steadily climbing keyword cohort, and revenue
            | you can trace back to a specific cluster of pages we shipped six months ago.
          p
            | I work with one or two clients at a time so the people paying me actually
            | get me, not an account manager. If we work together you will have my
            | number, my Slack, and my honest opinion when something is a bad idea.

        //- Highlight stats — hairline rail, not chips.
        .grid.grid-cols-2.border-t.border-border(class='mt-12 gap-y-8 gap-x-10 pt-10 sm:grid-cols-4')
          each h in highlights
            .flex.flex-col(class='gap-1')
              span.num-display.text-foreground(class='text-3xl md:text-4xl')= h.value
              span.font-mono.uppercase.text-muted-foreground(class='text-[0.65rem] tracking-[0.18em]')= h.label

      //- RIGHT — experience timeline + skills
      .flex.flex-col(class='gap-12 lg:col-span-5')
        div
          span.eyebrow Where I've been
          ol.flex.flex-col(class='mt-6')
            each item, idx in experience
              - var borderCls = idx === experience.length - 1 ? 'border-b' : ''
              li.group.relative.flex.items-baseline.justify-between.border-t.border-border.transition-colors.duration-300(class= 'gap-4 py-5 hover:bg-card/40 ' + borderCls)
                .flex.flex-col(class='gap-1')
                  span.font-serif.text-foreground(class='text-xl tracking-[-0.01em]')= item.role
                  span.text-muted-foreground(class='text-sm')= item.company
                span.font-mono.uppercase.text-muted-foreground.shrink-0(class='text-[0.65rem] tracking-[0.22em]')= item.period

        div
          span.eyebrow The toolbox
          ul.flex.flex-wrap(class='mt-6 gap-x-2 gap-y-2')
            each skill in skills
              li.inline-flex.items-center.rounded-full.border.border-border.font-mono.text-muted-foreground.transition-colors.duration-300(class='bg-card/40 px-3 py-1 text-[0.7rem] hover:text-foreground hover:border-foreground/30 hover:bg-card')= skill
