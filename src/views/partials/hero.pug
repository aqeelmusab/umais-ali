include icons.pug

section#top.relative.overflow-hidden(class='px-6 pt-32 pb-20 md:px-12 md:pt-44 md:pb-28 lg:px-20')

  //- Soft warm wash + grid (theme-aware via CSS vars)
  .pointer-events-none.absolute.inset-0(aria-hidden='true')
    .absolute.rounded-full(
      class='left-1/2 top-0 -translate-x-1/2 h-160 w-275 opacity-60'
      style='background:radial-gradient(circle, oklch(from var(--primary) l c h / 0.14), transparent 60%); filter:blur(80px);'
    )
    .absolute.inset-0(
      class='opacity-[0.06]'
      style='background-image:linear-gradient(var(--hero-grid-color) 1px, transparent 1px), linear-gradient(to right, var(--hero-grid-color) 1px, transparent 1px); background-size: 64px 64px; mask-image:radial-gradient(ellipse 80% 60% at 50% 30%, black 40%, transparent 80%); -webkit-mask-image:radial-gradient(ellipse 80% 60% at 50% 30%, black 40%, transparent 80%);'
    )

  .relative.mx-auto(class='max-w-6xl')

    //- Status pill + meta rail
    .flex.flex-wrap.items-center.justify-between.animate-fade-up(class='gap-4')
      span.inline-flex.items-center.rounded-full.border.border-border.font-mono.text-muted-foreground(
        class='gap-2.5 bg-card/60 pl-2 pr-3.5 py-1.5 text-xs backdrop-blur'
      )
        span.relative.inline-flex(class='h-2 w-2')
          span.absolute.inline-flex.animate-pulse-soft.rounded-full.bg-primary(class='h-full w-full')
          span.relative.inline-flex.rounded-full.bg-primary(class='h-2 w-2')
        | Booking one project for July
      span.hidden.font-mono.uppercase.text-muted-foreground(class='text-[0.65rem] tracking-[0.22em] sm:inline-flex items-center gap-2')
        span.h-px.w-6.bg-border
        | Lahore · Remote worldwide

    //- Editorial display headline
    h1.font-serif.text-foreground.animate-fade-up.stagger-1(
      class='mt-10 text-[clamp(2.75rem,7.6vw,6rem)] leading-[0.94] tracking-tight'
    )
      | SEO that actually
      br
      span.serif-italic.text-spotlight moves the needle.

    //- Subhead
    p.text-muted-foreground.animate-fade-up.stagger-2(class='mt-8 max-w-xl text-base md:text-lg leading-relaxed')
      | I'm Umais. I help teams turn search into a real growth channel,
      | not a slide deck full of vanity metrics. Audits, content systems,
      | link work, and migrations that hold up after the launch party.

    //- CTAs + keyboard hint
    .flex.flex-wrap.items-center.animate-fade-up.stagger-3(class='mt-10 gap-4')
      a.hover-glow.group.inline-flex.items-center.rounded-full.bg-foreground.font-medium.text-background.transition-all.duration-300(
        href='#contact'
        class='gap-2 h-12 pl-6 pr-5 text-sm hover:bg-foreground/90 active:scale-[0.98]'
      )
        | Start a project
        span.inline-flex.transition-transform.duration-300(class='group-hover:translate-x-0.5 group-hover:-translate-y-0.5')
          +icon('arrow-up-right', 'h-4 w-4')
      a.group.inline-flex.items-center.rounded-full.border.border-border.font-medium.text-foreground.transition-colors.duration-300(
        href='#work'
        class='gap-2 h-12 px-6 text-sm hover:border-foreground/40 hover:bg-foreground/3'
      )
        | See the work
        span.inline-flex.transition-transform.duration-300(class='group-hover:translate-y-0.5')
          +icon('arrow-down', 'h-4 w-4')

      span.hidden.items-center.font-mono.text-muted-foreground(class='gap-2 text-[0.7rem] sm:inline-flex ml-2')
        kbd.inline-flex.items-center.justify-center.rounded.border.border-border.bg-card(class='h-6 px-1.5 text-[0.65rem]') /
        span jump to work

    //- Stat rail
    .grid.grid-cols-1.border-t.border-border.animate-fade-up.stagger-4(class='mt-20 gap-8 pt-10 sm:grid-cols-3')
      each stat, idx in heroStats
        .flex.flex-col(class='gap-2')
          span.font-mono.uppercase.text-muted-foreground(class='text-xs tracking-[0.18em]') 0#{idx + 1} &nbsp;/&nbsp; #{stat.label}
          span.num-display.text-foreground(class='text-5xl md:text-6xl')= stat.value
