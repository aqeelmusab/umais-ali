section.marquee.relative.overflow-hidden.border-y.border-border(
  aria-label='What I work on'
  class='py-7 md:py-9 bg-card/30'
)
  //- Edge fade masks
  .pointer-events-none.absolute.inset-y-0.z-10(
    aria-hidden='true'
    class='marquee__fade marquee__fade--left left-0 w-20 md:w-32'
  )
  .pointer-events-none.absolute.inset-y-0.z-10(
    aria-hidden='true'
    class='marquee__fade marquee__fade--right right-0 w-20 md:w-32'
  )

  //- Single track containing two identical groups; CSS animates by exactly -50%
  //- so the second group seamlessly takes over the first.
  .marquee__track.flex.w-max.items-center
    - var groups = [false, true]
    each ariaHidden in groups
      ul.marquee__group.flex.shrink-0.items-center(class='gap-10 md:gap-14 pr-10 md:pr-14' aria-hidden=ariaHidden ? 'true' : 'false')
        each item, idx in marquee
          li.flex.shrink-0.items-center(class='gap-10 md:gap-14')
            span.font-serif.text-foreground.whitespace-nowrap(class='text-2xl md:text-4xl tracking-[-0.015em]')= item
            span.shrink-0.text-primary(aria-hidden='true' class= idx % 2 === 0 ? 'opacity-50' : 'opacity-30')
              if idx % 3 === 0
                | ✦
              else if idx % 3 === 1
                | ◆
              else
                | ●
