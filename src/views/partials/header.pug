include logo.pug
include icons.pug

header#site-nav.fixed.z-40.mx-auto.flex.items-center.justify-between.rounded-full.transition-all.duration-500(
  class='top-4 left-4 right-4 h-14 max-w-6xl px-3 md:top-6 md:left-8 md:right-8 md:px-4'
  aria-label='Primary'
)
  +logo()

  nav.hidden.items-center.gap-1(class='md:flex' aria-label='Primary navigation')
    each link in navLinks
      a.relative.rounded-full.font-medium.text-muted-foreground.transition-colors.duration-300(
        href=link.href
        class='px-4 py-2 text-sm hover:text-foreground hover:bg-foreground/4'
      )= link.label

  .flex.items-center(class='gap-1.5')
    button#theme-toggle.theme-toggle.inline-flex.items-center.justify-center.rounded-full.text-muted-foreground.transition-colors(
      type='button'
      aria-label='Toggle colour theme'
      class='h-10 w-10 hover:text-foreground hover:bg-foreground/5'
    )
      span.icon-moon.inline-flex
        +icon('moon', 'h-4 w-4')
      span.icon-sun.inline-flex
        +icon('sun', 'h-4 w-4')

    a.group.hidden.items-center.rounded-full.bg-foreground.font-medium.text-background.transition-all.duration-300(
      href='#contact'
      class='gap-2 h-10 pl-5 pr-4 text-sm md:inline-flex hover:bg-foreground/90'
    )
      span Let's talk
      span.inline-flex.transition-transform.duration-300(class='group-hover:translate-x-0.5 group-hover:-translate-y-0.5')
        +icon('arrow-up-right', 'h-3.5 w-3.5')

    button#mobile-menu-open.inline-flex.items-center.justify-center.rounded-full.text-foreground.transition-colors(
      type='button'
      aria-label='Open menu'
      aria-expanded='false'
      aria-controls='mobile-menu'
      class='h-10 w-10 md:hidden hover:bg-foreground/5'
    )
      +icon('menu', 'h-5 w-5')

//- ── Mobile sheet ──────────────────────────────────────
#mobile-menu.fixed.inset-0.z-50.flex.flex-col.bg-background(aria-hidden='true' inert class='md:hidden')
  .flex.items-center.justify-between(class='h-16 px-6')
    +logo()
    button#mobile-menu-close.inline-flex.items-center.justify-center.rounded-full.text-foreground.transition-colors(
      type='button'
      aria-label='Close menu'
      class='h-10 w-10 hover:bg-foreground/6'
    )
      +icon('x', 'h-5 w-5')

  nav.flex.flex-1.flex-col.justify-center(class='gap-1 px-8' aria-label='Mobile navigation')
    each link, idx in navLinks
      a.group.flex.items-baseline.border-b.border-border.text-foreground(
        href=link.href
        data-close-menu
        class='gap-4 py-5'
      )
        span.font-mono.text-muted-foreground(class='text-xs') 0#{idx + 1}
        span.font-serif.transition-transform.duration-300(class='text-4xl group-hover:translate-x-1')= link.label

  .flex.items-center.justify-between.border-t.border-border(class='gap-4 px-8 py-6')
    a.font-mono.lowercase.text-muted-foreground(class='text-xs tracking-[0.18em]' href='mailto:' + site.contactEmail)= site.contactEmail
    a.inline-flex.items-center.rounded-full.bg-foreground.font-medium.text-background(
      href='#contact'
      data-close-menu
      class='gap-2 h-11 px-5 text-sm'
    )
      | Let's talk
      +icon('arrow-up-right', 'h-3.5 w-3.5')
