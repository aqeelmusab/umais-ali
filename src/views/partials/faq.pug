include icons.pug

section#faq.relative(class='px-6 py-24 md:px-12 md:py-32 lg:px-20')
  .mx-auto(class='max-w-6xl')
    .grid.grid-cols-1(class='gap-12 lg:grid-cols-12 lg:gap-16')

      .flex.flex-col(class='lg:col-span-4')
        span.eyebrow Frequently asked
        h2.font-serif.text-foreground(class='mt-6 text-4xl md:text-5xl tracking-[-0.025em] leading-[1.05]')
          | The questions
          br
          span.serif-italic.text-muted-foreground I get a lot.
        p.text-muted-foreground(class='mt-6 text-sm md:text-base max-w-sm')
          | Did not see yours? Send a note. I read everything that comes through.

      .flex.flex-col(class='lg:col-span-8')
        each item in faqs
          details.group.border-b.border-border.transition-colors.duration-300(class='py-6 hover:border-foreground/30')
            summary.flex.cursor-pointer.list-none.items-center.justify-between(class='gap-6')
              span.font-serif.text-foreground(class='text-xl md:text-2xl tracking-[-0.015em] leading-snug')= item.q
              span.inline-flex.shrink-0.items-center.justify-center.rounded-full.border.border-border.text-muted-foreground.transition-all.duration-300(class='h-9 w-9 group-hover:text-foreground group-open:rotate-45 group-open:border-foreground/40 group-open:bg-card')
                +icon('plus', 'h-4 w-4')
            p.text-muted-foreground(class='mt-4 text-sm md:text-base leading-relaxed max-w-2xl')= item.a
