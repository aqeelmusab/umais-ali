include icons.pug

#project-modal.fixed.inset-0.z-50.flex.items-end.justify-center(
  aria-hidden='true'
  role='dialog'
  aria-modal='true'
  aria-labelledby='project-modal-title'
  class='p-0 md:items-center md:p-6'
)
  //- Backdrop
  .modal-backdrop.absolute.inset-0(
    aria-hidden='true'
    data-modal-close
  )

  //- Card
  .modal-card.relative.flex.w-full.flex-col.overflow-hidden.bg-card.shadow-2xl.border.border-border(
    class='h-[92vh] max-w-6xl rounded-t-2xl md:h-[88vh] md:rounded-2xl'
  )
    //- Body — populated by HTMX. The swapped content provides its own header.
    #project-modal-content.flex-1.overflow-y-auto
      .flex.h-full.items-center.justify-center.text-muted-foreground(class='text-sm') Loading…
