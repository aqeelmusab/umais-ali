---
import { CONTACT_EMAIL, homeSectionHref, navLinks } from '../../data/site'
import Icon from './Icon.astro'
import Logo from './Logo.astro'
---
<header id="site-nav" class="site-nav fixed z-40 mx-auto flex items-center justify-between rounded-full top-4 left-4 right-4 h-14 max-w-6xl px-3 md:top-6 md:left-8 md:right-8 md:px-4" aria-label="Primary">
  <Logo />

  <nav class="hidden items-center gap-1 md:flex" aria-label="Primary navigation">
    {navLinks.map((link) => (
      <a class="relative rounded-full font-medium text-muted-foreground transition-colors duration-300 px-4 py-2 text-sm hover:text-foreground hover:bg-foreground/4" href={link.href}>
        {link.label}
      </a>
    ))}
  </nav>

  <div class="flex items-center gap-1.5">
    <button id="theme-toggle" class="theme-toggle inline-flex items-center justify-center rounded-full text-muted-foreground transition-colors h-10 w-10 hover:text-foreground hover:bg-foreground/5" type="button" aria-label="Toggle colour theme">
      <span class="icon-moon inline-flex">
        <Icon name="moon" class="h-4 w-4" />
      </span>
      <span class="icon-sun inline-flex">
        <Icon name="sun" class="h-4 w-4" />
      </span>
    </button>

    <a class="group hidden items-center rounded-full bg-foreground font-medium text-background transition-all duration-300 gap-2 h-10 pl-5 pr-4 text-sm md:inline-flex md:-mr-1 hover:bg-foreground/90" href={homeSectionHref('contact')}>
      <span>Let's talk</span>
      <span class="inline-flex transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5">
        <Icon name="arrow-up-right" class="h-3.5 w-3.5" />
      </span>
    </a>

    <button id="mobile-menu-open" class="inline-flex items-center justify-center rounded-full text-foreground transition-colors h-10 w-10 md:hidden hover:bg-foreground/5" type="button" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
      <Icon name="menu" class="h-5 w-5" />
    </button>
  </div>
</header>

{/* -- Mobile sheet -------------------------------------- */}
<div id="mobile-menu" class="fixed inset-0 z-50 flex-col bg-background md:hidden hidden" aria-hidden="true" inert>
  <div class="flex items-center justify-between h-16 px-6">
    <Logo />
    <button id="mobile-menu-close" class="inline-flex items-center justify-center rounded-full text-foreground transition-colors h-10 w-10 hover:bg-foreground/6" type="button" aria-label="Close menu">
      <Icon name="x" class="h-5 w-5" />
    </button>
  </div>

  <nav class="flex flex-1 flex-col justify-center gap-1 px-8" aria-label="Mobile navigation">
    {navLinks.map((link, idx) => (
      <a class="group flex items-baseline border-b border-border text-foreground gap-4 py-5" href={link.href} data-close-menu>
        <span class="font-mono text-muted-foreground text-xs">0{idx + 1}</span>
        <span class="font-serif transition-transform duration-300 text-4xl group-hover:translate-x-1">{link.label}</span>
      </a>
    ))}
  </nav>

  <div class="flex items-center justify-between border-t border-border gap-4 px-8 py-6">
    <a class="font-mono lowercase text-muted-foreground text-xs tracking-[0.18em]" href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a>
    <a class="inline-flex items-center rounded-full bg-foreground font-medium text-background gap-2 h-11 px-5 text-sm" href={homeSectionHref('contact')} data-close-menu>
      Let's talk
      <Icon name="arrow-up-right" class="h-3.5 w-3.5" />
    </a>
  </div>
</div>
