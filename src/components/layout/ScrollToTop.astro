---
import Icon from './Icon.astro'
---
<button
  id="scroll-top"
  class="fixed bottom-6 right-6 z-30 inline-flex h-12 w-12 items-center justify-center rounded-full border border-line bg-surface-raised text-ink shadow-lg transition-colors hover:border-brand/40 hover:bg-surface-raised/90"
  type="button"
  aria-label="Scroll to top"
>
  <Icon name="arrow-up" class="h-5 w-5" />
</button>
