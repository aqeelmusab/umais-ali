---
import Icon from './Icon.astro';
import { navLinks, socialLinks, CONTACT_EMAIL, sectionHref } from '../../data/site';

const year = new Date().getFullYear();
---
<footer class="relative border-t border-border px-6 py-16 md:px-12 md:py-20 lg:px-20 bg-card/20">
  <div class="mx-auto max-w-6xl">
    <div class="grid grid-cols-1 gap-12 md:grid-cols-12">
      {/* LEFT: wordmark + line */}
      <div class="flex flex-col md:col-span-6 gap-4">
        <a class="inline-flex items-baseline font-serif text-foreground gap-1 text-2xl tracking-[-0.01em] hover:text-primary transition-colors" href={sectionHref('top')}>
          <span>Umais</span>
          <span class="serif-italic text-muted-foreground">Ali</span>
        </a>
        <p class="text-muted-foreground max-w-md text-sm leading-relaxed">
          Built with care, served from Lahore. If something here looks broken, that
          is on me. Send a note and I will fix it.
        </p>
      </div>

      {/* RIGHT: link columns */}
      <div class="grid grid-cols-2 md:col-span-6 gap-8 md:grid-cols-3">
        <nav class="flex flex-col gap-3">
          <span class="font-mono uppercase text-muted-foreground text-[0.65rem] tracking-[0.22em] mb-1">Site</span>
          {navLinks.map((link) => (
            <a class="text-foreground transition-colors text-sm hover:text-primary" href={link.href}>
              {link.label}
            </a>
          ))}
        </nav>

        <nav class="flex flex-col gap-3">
          <span class="font-mono uppercase text-muted-foreground text-[0.65rem] tracking-[0.22em] mb-1">Elsewhere</span>
          {socialLinks.map((link) => (
            <a class="text-foreground transition-colors text-sm hover:text-primary" href={link.href} target="_blank" rel="noopener noreferrer">
              {link.label}
            </a>
          ))}
        </nav>

        <div class="flex flex-col gap-3">
          <span class="font-mono uppercase text-muted-foreground text-[0.65rem] tracking-[0.22em] mb-1">Direct</span>
          <a class="text-foreground transition-colors text-sm hover:text-primary break-all" href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a>
          <a class="inline-flex items-center gap-1 text-sm hover:text-primary text-foreground transition-colors" href={sectionHref('top')}>
            <span>Back to top</span>
            <Icon name="arrow-up-right" class="h-3 w-3" />
          </a>
        </div>
      </div>
    </div>

    <div class="flex flex-col items-start justify-between border-t border-border gap-3 mt-14 pt-8 sm:flex-row sm:items-center">
      <p class="font-mono text-muted-foreground text-[0.7rem]">&copy; {year} Umais Ali. All rights reserved.</p>
      <p class="font-mono uppercase text-muted-foreground text-[0.65rem] tracking-[0.22em]">
        Lahore, PK · GMT+5
      </p>
    </div>
  </div>
</footer>
