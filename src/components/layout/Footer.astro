---
import { CONTACT_EMAIL, navLinks, sectionHref, socialLinks } from '../../data/site'
import Icon from './Icon.astro'

const year = new Date().getFullYear()
---
<footer class="relative border-t border-line px-6 py-16 md:px-12 md:py-20 lg:px-20 bg-surface">
  <div class="mx-auto max-w-6xl">
    <div class="grid grid-cols-1 gap-12 md:grid-cols-12">
      {/* LEFT: wordmark + line */}
      <div class="flex flex-col md:col-span-6 gap-4">
        <a class="inline-flex items-baseline font-serif text-ink gap-1 text-2xl tracking-[-0.01em] hover:text-brand transition-colors" href={sectionHref('top')}>
          <span>Umais</span>
          <span class="serif-italic text-spotlight-soft">Ali</span>
        </a>
        <p class="text-ink-muted max-w-md text-sm leading-relaxed">
          Built with care, served from Lahore. If something here looks broken, that
          is on me. Send a note and I will fix it.
        </p>
      </div>

      {/* RIGHT: link columns */}
      <div class="grid grid-cols-2 md:col-span-6 gap-8 md:grid-cols-3">
        <nav class="flex flex-col gap-3">
          <span class="font-mono uppercase text-ink-muted text-[0.65rem] tracking-[0.22em] mb-1">Site</span>
          {navLinks.map((link) => (
            <a class="text-ink transition-colors text-sm hover:text-brand" href={link.href}>
              {link.label}
            </a>
          ))}
        </nav>

        <nav class="flex flex-col gap-3">
          <span class="font-mono uppercase text-ink-muted text-[0.65rem] tracking-[0.22em] mb-1">Elsewhere</span>
          {socialLinks.map((link) => (
            <a class="text-ink transition-colors text-sm hover:text-brand" href={link.href} target="_blank" rel="noopener noreferrer">
              {link.label}
            </a>
          ))}
        </nav>

        <div class="flex flex-col gap-3">
          <span class="font-mono uppercase text-ink-muted text-[0.65rem] tracking-[0.22em] mb-1">Direct</span>
          <a class="text-ink transition-colors text-sm hover:text-brand break-all" href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a>
          <a class="inline-flex items-center gap-1 text-sm hover:text-brand text-ink transition-colors" href={sectionHref('top')}>
            <span>Back to top</span>
            <Icon name="arrow-up-right" class="h-3 w-3" />
          </a>
        </div>
      </div>
    </div>

    <div class="flex flex-col items-start justify-between border-t border-line gap-3 mt-14 pt-8 sm:flex-row sm:items-center">
      <p class="inline-flex items-center font-mono text-ink-muted text-[0.7rem]"><span class="text-brand-soft mr-1 text-sm">&copy;</span>{year} Umais Ali. All rights reserved.</p>
      <p class="font-mono uppercase text-ink-muted text-[0.65rem] tracking-[0.22em]">
        Lahore, PK · GMT+5
      </p>
    </div>
  </div>
</footer>
