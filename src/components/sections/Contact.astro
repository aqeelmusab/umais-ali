---
import { CONTACT_EMAIL, socialLinks } from '../../data/site'
import Icon from '../layout/Icon.astro'

interface Props {
  values?: { name?: string; email?: string; message?: string }
  errors?: { name?: string; email?: string; message?: string }
}

const { values = {}, errors = {} } = Astro.props as Props
---
<section id="contact" class="relative px-6 py-24 md:px-12 md:py-32 lg:px-20">
  <div class="mx-auto max-w-6xl">
    <div class="grid grid-cols-1 gap-16 lg:grid-cols-12 lg:gap-20">

      {/* LEFT: invitation */}
      <div class="flex flex-col lg:col-span-5">
        <span class="eyebrow">Get in touch</span>
        <h2 class="font-serif text-foreground mt-6 text-4xl md:text-5xl tracking-tight leading-[1.05]">
          Got something
          <br />
          <span class="serif-italic text-muted-foreground">worth shipping?</span>
        </h2>
        <p class="text-muted-foreground mt-8 max-w-md text-base md:text-lg leading-relaxed">
          Tell me a bit about your team, what you are stuck on,
          and where you would like to be in twelve months. Most replies go out
          within a day. Shorter notes are very welcome.
        </p>

        <div class="flex flex-col mt-12 gap-8">
          <div class="flex flex-col gap-2">
            <span class="font-mono uppercase text-muted-foreground text-[0.65rem] tracking-[0.22em]">Email</span>
            <a class="group inline-flex items-center font-serif text-foreground transition-colors gap-2 text-xl hover:text-primary" href={`mailto:${CONTACT_EMAIL}`}>
              <span>{CONTACT_EMAIL}</span>
              <span class="inline-flex transition-transform duration-300 translate-y-px group-hover:translate-x-0.5 group-hover:-translate-y-0.5">
                <Icon name="arrow-up-right" class="h-4 w-4" />
              </span>
            </a>
          </div>

          <div class="flex flex-col gap-2">
            <span class="font-mono uppercase text-muted-foreground text-[0.65rem] tracking-[0.22em]">Around the web</span>
            <ul class="flex flex-wrap gap-x-4 gap-y-2">
              {socialLinks.map((link) => (
                <li>
                  <a class="group inline-flex items-center text-muted-foreground transition-colors gap-1 text-sm hover:text-foreground" href={link.href} target="_blank" rel="noopener noreferrer">
                    <span>{link.label}</span>
                    <span class="inline-flex transition-opacity duration-300 opacity-0 group-hover:opacity-100">
                      <Icon name="arrow-up-right" class="h-3.5 w-3.5" />
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <div class="flex items-center border-t border-border gap-3 pt-8 mt-2">
            <span class="relative inline-flex h-2 w-2">
              <span class="absolute inline-flex animate-pulse-soft rounded-full bg-primary h-full w-full"></span>
              <span class="relative inline-flex rounded-full bg-primary h-2 w-2"></span>
            </span>
            <span class="font-mono uppercase text-muted-foreground text-[0.65rem] tracking-[0.22em]">Currently taking work for July onwards</span>
          </div>
        </div>
      </div>

      {/* RIGHT: form on a quiet card */}
      <div class="flex flex-col lg:col-span-7">
        <div class="rounded-lg border border-border bg-card/40 p-6 md:p-10">
          <div id="contact-form-wrap">
            <form
              id="contact-form"
              class="flex flex-col gap-5"
              action="/api/contact"
              method="POST"
              novalidate
            >
              <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
                {/* Name field */}
                <label class="block" for="cf-name">
                  <span class="block font-mono uppercase text-muted-foreground mb-2 text-[0.65rem] tracking-[0.22em]">Name</span>
                  <input
                    id="cf-name"
                    name="name"
                    type="text"
                    value={values.name || ""}
                    autocomplete="name"
                    placeholder="Your name"
                    required
                    aria-invalid={errors.name ? "true" : "false"}
                    aria-describedby={errors.name ? "cf-name-err" : undefined}
                    class:list={[
                      "w-full rounded-xl bg-background/60 border px-4 py-3 text-sm text-foreground placeholder:text-muted-foreground/50 outline-none transition-colors focus:bg-background",
                      errors.name ? "border-destructive focus:border-destructive" : "border-border focus:border-foreground/40"
                    ]}
                  />
                  {errors.name && (
                    <p class="text-destructive mt-2 text-xs" id="cf-name-err">{errors.name}</p>
                  )}
                </label>

                {/* Email field */}
                <label class="block" for="cf-email">
                  <span class="block font-mono uppercase text-muted-foreground mb-2 text-[0.65rem] tracking-[0.22em]">Email</span>
                  <input
                    id="cf-email"
                    name="email"
                    type="email"
                    value={values.email || ""}
                    autocomplete="email"
                    placeholder="you@domain.com"
                    required
                    aria-invalid={errors.email ? "true" : "false"}
                    aria-describedby={errors.email ? "cf-email-err" : undefined}
                    class:list={[
                      "w-full rounded-xl bg-background/60 border px-4 py-3 text-sm text-foreground placeholder:text-muted-foreground/50 outline-none transition-colors focus:bg-background",
                      errors.email ? "border-destructive focus:border-destructive" : "border-border focus:border-foreground/40"
                    ]}
                  />
                  {errors.email && (
                    <p class="text-destructive mt-2 text-xs" id="cf-email-err">{errors.email}</p>
                  )}
                </label>
              </div>

              {/* Message field */}
              <label class="block" for="cf-message">
                <span class="block font-mono uppercase text-muted-foreground mb-2 text-[0.65rem] tracking-[0.22em]">What is the project?</span>
                <textarea
                  id="cf-message"
                  name="message"
                  rows="5"
                  autocomplete="off"
                  placeholder="A couple of sentences is plenty. Links are great too."
                  required
                  aria-invalid={errors.message ? "true" : "false"}
                  aria-describedby={errors.message ? "cf-message-err" : undefined}
                  class:list={[
                    "w-full rounded-xl bg-background/60 border px-4 py-3 text-sm text-foreground placeholder:text-muted-foreground/50 outline-none transition-colors focus:bg-background resize-y min-h-[10rem]",
                    errors.message ? "border-destructive focus:border-destructive" : "border-border focus:border-foreground/40"
                  ]}
                >{values.message || ""}</textarea>
                {errors.message && (
                  <p class="text-destructive mt-2 text-xs" id="cf-message-err">{errors.message}</p>
                )}
              </label>

              {/* Honeypot: hidden from real users, irresistible to bots */}
              <div aria-hidden="true" class="absolute left-[-2499.75px] top-auto h-px w-px overflow-hidden">
                <label for="cf-website">Leave this field empty</label>
                <input id="cf-website" name="website" type="text" tabindex="-1" autocomplete="off" />
              </div>

              <div class="flex flex-wrap items-center gap-4 pt-2">
                <button
                  type="submit"
                  class="hover-glow group inline-flex items-center justify-center rounded-full bg-foreground font-medium text-background transition-all duration-300 gap-3 h-12 px-7 text-sm hover:bg-foreground/90 active:scale-[0.98] disabled:opacity-60 disabled:cursor-wait"
                >
                  <span class="indicator-hide inline-flex items-center gap-2">
                    Send it over
                    <span class="inline-flex transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5">
                      <Icon name="arrow-up-right" class="h-3.5 w-3.5" />
                    </span>
                  </span>
                  <span class="indicator inline-flex items-center gap-2 hidden">
                    <svg class="animate-spin h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <circle cx="12" cy="12" r="10" stroke-opacity="0.25"></circle>
                      <path d="M22 12a10 10 0 0 1-10 10" stroke-linecap="round"></path>
                    </svg>
                    Sending
                  </span>
                </button>
                <p class="text-muted-foreground text-xs font-sans">No newsletters, no follow up sequence. Just a real reply from me.</p>
              </div>
            </form>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
