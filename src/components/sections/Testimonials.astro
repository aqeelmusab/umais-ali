---
import { testimonials } from '../../data/site'
---
<section id="testimonials" class="relative px-6 py-24 md:px-12 md:py-28 lg:px-20">
  <div class="mx-auto max-w-6xl">
    <div class="flex flex-col border-b border-line gap-2 pb-10">
      <span class="eyebrow">Kind words</span>
      <h2 class="font-serif text-ink mt-6 text-4xl md:text-5xl tracking-tight leading-[1.05]">
        What people
        <span class="serif-italic text-spotlight-soft"> actually said.</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 mt-12 gap-px bg-line md:grid-cols-2">
      {testimonials.map((t) => (
        <figure class="flex flex-col bg-surface gap-8 p-8 lg:p-12">
          <span class="font-serif text-brand leading-none text-7xl" aria-hidden="true">&ldquo;</span>
          <blockquote class="font-serif text-ink text-xl md:text-2xl tracking-[-0.015em] leading-snug -mt-4">
            {t.quote}
          </blockquote>
          <figcaption class="flex items-center border-t border-line pt-6 mt-auto gap-4">
            <span class="inline-flex items-center justify-center rounded-full bg-surface-raised font-serif text-ink border border-line h-11 w-11 text-base">
              {t.author.split(' ').map((s) => s.charAt(0)).join('')}
            </span>
            <div class="flex flex-col leading-tight">
              <span class="text-ink text-sm font-medium">{t.author}</span>
              <span class="font-mono text-ink-muted text-[0.7rem] mt-0.5">{t.role}</span>
            </div>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
