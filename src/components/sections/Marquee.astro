---
import { marquee } from '../../data/site'

const groups = [false, true]
---
<section class="marquee relative overflow-hidden border-y border-border py-7 md:py-9 bg-card/30" aria-label="What I work on">
  {/* Edge fade masks */}
  <div class="pointer-events-none absolute inset-y-0 z-10 marquee__fade marquee__fade--left left-0 w-20 md:w-32" aria-hidden="true"></div>
  <div class="pointer-events-none absolute inset-y-0 z-10 marquee__fade marquee__fade--right right-0 w-20 md:w-32" aria-hidden="true"></div>

  {/* Single track containing two identical groups; CSS animates by exactly -50%
      so the second group seamlessly takes over the first. */}
  <div class="marquee__track flex w-max items-center">
    {groups.map((ariaHidden) => (
      <ul class="marquee__group flex shrink-0 items-center gap-10 md:gap-14 pr-10 md:pr-14" aria-hidden={ariaHidden ? "true" : "false"}>
        {marquee.map((item, idx) => (
          <li class="flex shrink-0 items-center gap-10 md:gap-14">
            <span class="font-serif text-foreground whitespace-nowrap text-2xl md:text-4xl tracking-[-0.015em]">{item}</span>
            <span class="shrink-0 text-primary opacity-30" aria-hidden="true" class:list={[{ 'opacity-50': idx % 2 === 0, 'opacity-30': idx % 2 !== 0 }]}>
              {idx % 3 === 0 && '✦'}
              {idx % 3 === 1 && '◆'}
              {idx % 3 !== 0 && idx % 3 !== 1 && '●'}
            </span>
          </li>
        ))}
      </ul>
    ))}
  </div>
</section>
