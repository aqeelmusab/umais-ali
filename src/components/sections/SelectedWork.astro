---
import { projects } from '../../data/projects'
import Icon from '../layout/Icon.astro'
---
<section id="work" class="relative px-6 py-24 md:px-12 md:py-32 lg:px-20">
  <div class="mx-auto max-w-6xl">
    {/* Section header */}
    <div class="flex flex-col border-b border-border gap-6 pb-12 md:flex-row md:items-end md:justify-between">
      <div>
        <span class="eyebrow">Selected work</span>
        <h2 class="font-serif text-foreground mt-6 text-4xl md:text-5xl tracking-tight leading-[1.05]">
          Five projects,
          <br />
          <span class="serif-italic text-muted-foreground">one common thread.</span>
        </h2>
      </div>
      <div class="flex flex-col gap-3 max-w-md">
        <p class="text-muted-foreground text-sm md:text-base">
          Each one started with a team that had been told their SEO was fine.
          It was not. Tap any case to read what we actually changed.
        </p>
        <span class="font-mono uppercase text-muted-foreground text-[0.65rem] tracking-[0.22em]">
          0{projects.length} cases · 2024 to 2025
        </span>
      </div>
    </div>

    {/* Bento grid */}
    <div class="grid grid-cols-1 mt-12 gap-5 md:grid-cols-12 md:gap-6">
      {/* Card 1 */}
      {projects[0] && (
        <article class="bento-card reveal group md:col-span-7 min-h-88 md:min-h-104">
          <a
            class="relative flex h-full w-full flex-col overflow-hidden text-left"
            href={`/projects/${projects[0].slug}`}
            data-project-trigger
            data-project-id={projects[0].id}
            aria-label={`Open ${projects[0].title} case study`}
          >
            <img class="bento-image absolute inset-0 h-full w-full object-cover" src={projects[0].image} alt={projects[0].title} loading="lazy" decoding="async" />
            <div class="project-vignette pointer-events-none absolute inset-0" aria-hidden="true"></div>
            <div class="relative z-10 flex items-center justify-between p-5 lg:p-7">
              <span class="font-mono uppercase rounded-full text-[0.65rem] tracking-[0.2em] backdrop-blur bg-background/40 px-2.5 py-1 text-foreground/85">
                0{projects[0].id} · {projects[0].year}
              </span>
              {projects[0].result && (
                <span class="inline-flex items-center font-mono uppercase rounded-full text-primary gap-1.5 text-[0.65rem] tracking-[0.18em] bg-primary/8 px-2.5 py-1 backdrop-blur">
                  <span class="rounded-full bg-primary animate-pulse-soft h-1.5 w-1.5"></span>
                  <span>{projects[0].result}</span>
                </span>
              )}
            </div>
            <div class="relative flex-1"></div>
            <div class="relative z-10 flex items-end justify-between gap-4 p-6 lg:p-8">
              <div class="flex flex-col gap-2 min-w-0">
                <span class="font-mono uppercase text-muted-foreground text-[0.65rem] tracking-[0.22em]">{projects[0].category}</span>
                <h3 class="font-serif text-foreground text-2xl md:text-3xl tracking-[-0.02em] leading-[1.05]">{projects[0].title}</h3>
              </div>
              <span class="inline-flex shrink-0 items-center justify-center rounded-full text-foreground transition-all duration-300 h-11 w-11 bg-background/40 backdrop-blur group-hover:bg-foreground group-hover:text-background group-hover:-rotate-12">
                <Icon name="arrow-up-right" class="h-4 w-4" />
              </span>
            </div>
          </a>
        </article>
      )}

      {/* Card 2 */}
      {projects[1] && (
        <article class="bento-card reveal group md:col-span-5 min-h-[22rem] md:min-h-[26rem]">
          <a
            class="relative flex h-full w-full flex-col overflow-hidden text-left"
            href={`/projects/${projects[1].slug}`}
            data-project-trigger
            data-project-id={projects[1].id}
            aria-label={`Open ${projects[1].title} case study`}
          >
            <img class="bento-image absolute inset-0 h-full w-full object-cover" src={projects[1].image} alt={projects[1].title} loading="lazy" decoding="async" />
            <div class="project-vignette pointer-events-none absolute inset-0" aria-hidden="true"></div>
            <div class="relative z-10 flex items-center justify-between p-5 lg:p-7">
              <span class="font-mono uppercase rounded-full text-[0.65rem] tracking-[0.2em] backdrop-blur bg-background/40 px-2.5 py-1 text-foreground/85">
                0{projects[1].id} · {projects[1].year}
              </span>
              {projects[1].result && (
                <span class="inline-flex items-center font-mono uppercase rounded-full text-primary gap-1.5 text-[0.65rem] tracking-[0.18em] bg-primary/8 px-2.5 py-1 backdrop-blur">
                  <span class="rounded-full bg-primary animate-pulse-soft h-1.5 w-1.5"></span>
                  <span>{projects[1].result}</span>
                </span>
              )}
            </div>
            <div class="relative flex-1"></div>
            <div class="relative z-10 flex items-end justify-between gap-4 p-6 lg:p-8">
              <div class="flex flex-col gap-2 min-w-0">
                <span class="font-mono uppercase text-muted-foreground text-[0.65rem] tracking-[0.22em]">{projects[1].category}</span>
                <h3 class="font-serif text-foreground text-2xl md:text-3xl tracking-[-0.02em] leading-[1.05]">{projects[1].title}</h3>
              </div>
              <span class="inline-flex shrink-0 items-center justify-center rounded-full text-foreground transition-all duration-300 h-11 w-11 bg-background/40 backdrop-blur group-hover:bg-foreground group-hover:text-background group-hover:-rotate-12">
                <Icon name="arrow-up-right" class="h-4 w-4" />
              </span>
            </div>
          </a>
        </article>
      )}

      {/* Card 3 */}
      {projects[2] && (
        <article class="bento-card reveal group md:col-span-6 min-h-[22rem] md:min-h-[26rem]">
          <a
            class="relative flex h-full w-full flex-col overflow-hidden text-left"
            href={`/projects/${projects[2].slug}`}
            data-project-trigger
            data-project-id={projects[2].id}
            aria-label={`Open ${projects[2].title} case study`}
          >
            <img class="bento-image absolute inset-0 h-full w-full object-cover" src={projects[2].image} alt={projects[2].title} loading="lazy" decoding="async" />
            <div class="project-vignette pointer-events-none absolute inset-0" aria-hidden="true"></div>
            <div class="relative z-10 flex items-center justify-between p-5 lg:p-7">
              <span class="font-mono uppercase rounded-full text-[0.65rem] tracking-[0.2em] backdrop-blur bg-background/40 px-2.5 py-1 text-foreground/85">
                0{projects[2].id} · {projects[2].year}
              </span>
              {projects[2].result && (
                <span class="inline-flex items-center font-mono uppercase rounded-full text-primary gap-1.5 text-[0.65rem] tracking-[0.18em] bg-primary/8 px-2.5 py-1 backdrop-blur">
                  <span class="rounded-full bg-primary animate-pulse-soft h-1.5 w-1.5"></span>
                  <span>{projects[2].result}</span>
                </span>
              )}
            </div>
            <div class="relative flex-1"></div>
            <div class="relative z-10 flex items-end justify-between gap-4 p-6 lg:p-8">
              <div class="flex flex-col gap-2 min-w-0">
                <span class="font-mono uppercase text-muted-foreground text-[0.65rem] tracking-[0.22em]">{projects[2].category}</span>
                <h3 class="font-serif text-foreground text-2xl md:text-3xl tracking-[-0.02em] leading-[1.05]">{projects[2].title}</h3>
              </div>
              <span class="inline-flex shrink-0 items-center justify-center rounded-full text-foreground transition-all duration-300 h-11 w-11 bg-background/40 backdrop-blur group-hover:bg-foreground group-hover:text-background group-hover:-rotate-12">
                <Icon name="arrow-up-right" class="h-4 w-4" />
              </span>
            </div>
          </a>
        </article>
      )}

      {/* Card 4 */}
      {projects[3] && (
        <article class="bento-card reveal group md:col-span-6 min-h-[22rem] md:min-h-[26rem]">
          <a
            class="relative flex h-full w-full flex-col overflow-hidden text-left"
            href={`/projects/${projects[3].slug}`}
            data-project-trigger
            data-project-id={projects[3].id}
            aria-label={`Open ${projects[3].title} case study`}
          >
            <img class="bento-image absolute inset-0 h-full w-full object-cover" src={projects[3].image} alt={projects[3].title} loading="lazy" decoding="async" />
            <div class="project-vignette pointer-events-none absolute inset-0" aria-hidden="true"></div>
            <div class="relative z-10 flex items-center justify-between p-5 lg:p-7">
              <span class="font-mono uppercase rounded-full text-[0.65rem] tracking-[0.2em] backdrop-blur bg-background/40 px-2.5 py-1 text-foreground/85">
                0{projects[3].id} · {projects[3].year}
              </span>
              {projects[3].result && (
                <span class="inline-flex items-center font-mono uppercase rounded-full text-primary gap-1.5 text-[0.65rem] tracking-[0.18em] bg-primary/8 px-2.5 py-1 backdrop-blur">
                  <span class="rounded-full bg-primary animate-pulse-soft h-1.5 w-1.5"></span>
                  <span>{projects[3].result}</span>
                </span>
              )}
            </div>
            <div class="relative flex-1"></div>
            <div class="relative z-10 flex items-end justify-between gap-4 p-6 lg:p-8">
              <div class="flex flex-col gap-2 min-w-0">
                <span class="font-mono uppercase text-muted-foreground text-[0.65rem] tracking-[0.22em]">{projects[3].category}</span>
                <h3 class="font-serif text-foreground text-2xl md:text-3xl tracking-[-0.02em] leading-[1.05]">{projects[3].title}</h3>
              </div>
              <span class="inline-flex shrink-0 items-center justify-center rounded-full text-foreground transition-all duration-300 h-11 w-11 bg-background/40 backdrop-blur group-hover:bg-foreground group-hover:text-background group-hover:-rotate-12">
                <Icon name="arrow-up-right" class="h-4 w-4" />
              </span>
            </div>
          </a>
        </article>
      )}

      {/* Card 5 (Feature Card) */}
      {projects[4] && (
        <article class="bento-card reveal group md:col-span-12 min-h-[26rem] md:min-h-[34rem]">
          <a
            class="relative flex h-full w-full flex-col overflow-hidden text-left"
            href={`/projects/${projects[4].slug}`}
            data-project-trigger
            data-project-id={projects[4].id}
            aria-label={`Open ${projects[4].title} case study`}
          >
            <img class="bento-image absolute inset-0 h-full w-full object-cover" src={projects[4].image} alt={projects[4].title} loading="lazy" decoding="async" />
            <div class="project-vignette pointer-events-none absolute inset-0" aria-hidden="true"></div>
            <div class="relative z-10 flex items-center justify-between p-5 lg:p-7">
              <span class="font-mono uppercase rounded-full text-[0.65rem] tracking-[0.2em] backdrop-blur bg-background/40 px-2.5 py-1 text-foreground/85">
                0{projects[4].id} · {projects[4].year}
              </span>
              {projects[4].result && (
                <span class="inline-flex items-center font-mono uppercase rounded-full text-primary gap-1.5 text-[0.65rem] tracking-[0.18em] bg-primary/8 px-2.5 py-1 backdrop-blur">
                  <span class="rounded-full bg-primary animate-pulse-soft h-1.5 w-1.5"></span>
                  <span>{projects[4].result}</span>
                </span>
              )}
            </div>
            <div class="relative flex-1"></div>
            <div class="relative z-10 flex items-end justify-between gap-4 p-6 lg:p-8">
              <div class="flex flex-col gap-2 min-w-0">
                <span class="font-mono uppercase text-muted-foreground text-[0.65rem] tracking-[0.22em]">{projects[4].category}</span>
                <h3 class="font-serif text-foreground text-3xl md:text-5xl tracking-[-0.02em] leading-[1.05]">{projects[4].title}</h3>
                <p class="text-muted-foreground line-clamp-2 hidden text-sm max-w-md lg:block mt-1">{projects[4].description}</p>
              </div>
              <span class="inline-flex shrink-0 items-center justify-center rounded-full text-foreground transition-all duration-300 h-11 w-11 bg-background/40 backdrop-blur group-hover:bg-foreground group-hover:text-background group-hover:-rotate-12">
                <Icon name="arrow-up-right" class="h-4 w-4" />
              </span>
            </div>
          </a>
        </article>
      )}
    </div>
  </div>
</section>
